---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Platform Access" showTimer={true}>
    <div class="page-header">
        <div class="container">
            <h1>Platform Access</h1>
            <p>Welcome to the NGnI analysis and project management portal.</p>
        </div>
    </div>

    <section>
        <div class="container">
            <!-- Pre-launch state (default) -->
            <div
                id="pre-launch"
                style="max-width:640px;margin:0 auto;text-align:center;"
            >
                <div class="alert alert-info">
                    <strong>New delivery.</strong> Authenticate with your delivery
                    code and press the button below to begin your delivery.
                </div>

                <div
                    id="access-code-card"
                    class="card mt-3"
                    style="text-align:left;"
                >
                    <h3>Delivery Code</h3>
                    <p class="text-muted" style="font-size:0.9rem;">
                        Enter the access code provided by your project
                        coordinator.
                    </p>
                    <div class="form-group">
                        <label for="access-code">Access Code</label>
                        <div
                            style="display:flex;gap:0.5rem;align-items:center;"
                        >
                            <input
                                type="password"
                                id="access-code"
                                placeholder="••••••••••••"
                                autocomplete="off"
                                style="flex:1;"
                            />
                            <button
                                type="button"
                                id="toggle-code"
                                title="Show/hide code"
                                style="background:transparent;border:1px solid rgba(255,255,255,0.3);border-radius:4px;padding:0.35rem 0.6rem;cursor:pointer;font-size:1rem;line-height:1;"
                                >🔓</button
                            >
                        </div>
                    </div>
                    <div
                        id="access-code-error"
                        style="display:none;color:#c0392b;font-size:0.85rem;margin-top:0.25rem;"
                    >
                        ❌ Invalid access code. Please try again.
                    </div>
                </div>

                <!-- Team mode -->
                <div id="team-auth" style="display:none;">
                    <div class="card mt-3" style="text-align:left;">
                        <h3>Team Authentication</h3>
                        <p class="text-muted" style="font-size:0.9rem;">
                            Enter your team name and leader as registered in
                            your form.
                        </p>
                        <div class="form-group">
                            <label for="team-name">Team Name</label>
                            <input
                                type="text"
                                id="team-name"
                                placeholder="e.g. The Gnome Rangers"
                            />
                        </div>
                        <div class="form-group">
                            <label for="team-leader">Team Leader</label>
                            <input
                                type="text"
                                id="team-leader"
                                placeholder="First name"
                            />
                        </div>
                    </div>
                    <button
                        id="launch-btn-mixed"
                        class="btn btn-primary mt-3"
                        style="font-size:1.1rem;padding:0.9rem 2.5rem;width:100%;"
                    >
                        🚀 Initialise Platform
                    </button>
                </div>

                <button
                    id="verify-btn"
                    class="btn btn-primary mt-3"
                    style="font-size:1.1rem;padding:0.9rem 2.5rem;width:100%;"
                >
                    🔑 Verify Delivery Code
                </button>
            </div>

            <!-- Post-launch state (hidden until button press) -->
            <div
                id="post-launch"
                style="display:none;margin:0 auto;"
            >
                <div class="alert alert-success" style="max-width:888px;margin-left:auto;margin-right:auto;">
                    Welcome <span id="display-team"></span>, Project Delivery
                    <span id="delivery-status">starting</span>.
                </div>

                <div class="cards mt-3">
                    <a
                        href="/platform/species-id/"
                        class="card"
                        id="card-species-id"
                        style="text-decoration:none;cursor:pointer;"
                    >
                        <div class="card-icon">🔬</div>
                        <h3>Species Identification</h3>
                        <p>
                            Identify the spirit animal of the Project
                            Coordinator in charge of your delivery project.
                        </p>
                        <span
                            class="btn btn-outline"
                            style="font-size:0.85rem;padding:0.4rem 0.9rem;"
                            >Open Tool →</span
                        >
                    </a>
                    <div id="card-submit" class="card" style="display:none;">
                        <div class="card-icon">🔍</div>
                        <h3>Project Retrieval</h3>
                        <p>
                             Enter the Project Coordinator's spirit animal to retrieve your project
                            and learn which envelope to open.
                        </p>
                        <span
                            class="btn btn-outline"
                            style="font-size:0.85rem;padding:0.4rem 0.9rem;"
                            >Open Tool →</span
                        >
                    </div>
                    <div id="card-next" class="card" style="display:none;">
                        <div class="card-icon">🔮</div>
                        <h3>Next Step</h3>
                        <p>
                            The next challenge will appear here once you've
                            opened the envelope.
                        </p>
                        <span
                            class="btn btn-outline"
                            style="font-size:0.85rem;padding:0.4rem 0.9rem;opacity:0.5;"
                            >Coming Soon</span
                        >
                    </div>
                </div>
        </div>
    </section>
</Layout>

<script>
    const H = [
        "b2b330e0386fe31701efbf1e9538cc4908c91c184a70bb2f32585f442e9f4869",
        "b9009c67797d87e79c78875dbf16270f6fe0f9f372b6068e492f6befec213b19",
        "469d6bce0f02660b066ab925af9636f76a29d04ade3020edddcbd79f5cfbd00e",
        "fc6b45835d52afa67df948550ec275ef285fb5b2c6dad04e818f0cd75df796c9",
        "9b395e132d77dfd654391e2e4735250e796fcaa5ab3dc64d002a1ee0669c5d91",
        "714ac0a71d346e132d7080b74c871550fe8012d34db6567866224f4fbf0a8627",
    ];

    const launchBtnMixed = document.getElementById("launch-btn-mixed");
    const verifyBtn = document.getElementById("verify-btn");
    const preLaunch = document.getElementById("pre-launch");
    const postLaunch = document.getElementById("post-launch");
    const displayTeam = document.getElementById("display-team");
    const teamAuth = document.getElementById("team-auth");
    const codeCard = document.getElementById("access-code-card");
    const codeError = document.getElementById("access-code-error");
    const toggleBtn = document.getElementById("toggle-code");
    const codeInput = document.getElementById(
        "access-code",
    ) as HTMLInputElement;

    toggleBtn?.addEventListener("click", () => {
        const isHidden = codeInput.type === "password";
        codeInput.type = isHidden ? "text" : "password";
        toggleBtn.textContent = isHidden ? "🔒" : "🔓";
    });

    // Restore session if already started, or auto-restart if credentials are present (after a restart)
    const existingStart = localStorage.getItem("gnomics_start");
    const existingMode = localStorage.getItem("gnomics_mode");
    if (existingMode && !existingStart) {
        localStorage.setItem("gnomics_start", String(Date.now()));
        window.dispatchEvent(new Event("gnomics_started"));
    }
    if (existingMode) {
        const displayName =
            localStorage.getItem("gnomics_team") || "you";
        preLaunch!.style.display = "none";
        postLaunch!.style.display = "block";
        displayTeam!.textContent = displayName;
        if (
            localStorage.getItem("gnomics_species_done") ||
            localStorage.getItem("gnomics_accession")
        ) {
            document.getElementById("delivery-status")!.textContent = "ongoing";
        }
        if (localStorage.getItem("gnomics_species_done")) {
            unlockCards();
            const card = document.getElementById(
                "card-species-id",
            ) as HTMLAnchorElement;
            if (card) {
                card.removeAttribute("href");
                card.style.cursor = "default";
                card.style.opacity = "0.5";
                card.querySelector(".btn")!.textContent = "✅ Completed";
            }
        }
        if (localStorage.getItem("gnomics_accession")) {
            const card = document.getElementById(
                "card-submit",
            ) as HTMLElement;
            if (card) {
                card.style.cursor = "default";
                card.style.opacity = "0.5";
                card.querySelector(".btn")!.textContent = "✅ Completed";
            }
            document.getElementById("card-next")!.style.display = "block";
        }
    }

    async function sha256(str: string): Promise<string> {
        const buf = await crypto.subtle.digest(
            "SHA-256",
            new TextEncoder().encode(str),
        );
        return Array.from(new Uint8Array(buf))
            .map((b) => b.toString(16).padStart(2, "0"))
            .join("");
    }

    codeInput?.addEventListener("keydown", (e) => {
        if (e.key === "Enter") verifyBtn?.click();
    });

    verifyBtn?.addEventListener("click", async () => {
        const code = codeInput?.value.trim();
        if (!code) return;
        const hash = await sha256(code);
        if (!H.includes(hash)) {
            codeError!.style.display = "block";
            return;
        }
        codeCard!.style.display = "none";
        verifyBtn!.style.display = "none";
        localStorage.setItem("gnomics_mode", "mixed");
        localStorage.setItem("gnomics_code_idx", String(H.indexOf(hash)));
        teamAuth!.style.display = "block";
    });

    function startSession(displayName: string) {
        localStorage.setItem("gnomics_start", String(Date.now()));
        preLaunch!.style.display = "none";
        postLaunch!.style.display = "block";
        displayTeam!.textContent = displayName;
        window.dispatchEvent(new Event("gnomics_started"));
        location.reload();
    }

    document.getElementById("team-name")?.addEventListener("keydown", (e) => {
        if (e.key === "Enter") launchBtnMixed?.click();
    });
    document.getElementById("team-leader")?.addEventListener("keydown", (e) => {
        if (e.key === "Enter") launchBtnMixed?.click();
    });

    launchBtnMixed?.addEventListener("click", () => {
        const teamName = (
            document.getElementById("team-name") as HTMLInputElement
        )?.value.trim();
        const teamLeader = (
            document.getElementById("team-leader") as HTMLInputElement
        )?.value.trim();
        if (!teamName || !teamLeader) {
            alert("Please enter your team name and leader before starting.");
            return;
        }
        localStorage.setItem("gnomics_team", teamName);
        localStorage.setItem("gnomics_leader", teamLeader);
        startSession(teamName);
    });

    function unlockCards() {
        const card = document.getElementById("card-submit") as HTMLElement;
        if (card) {
            card.style.display = "block";
            card.style.cursor = "pointer";
            card.onclick = () => {
                window.location.href = "/platform/retrieval/";
            };
        }
    }
</script>
