---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Platform Access" showTimer={true}>

  <div class="page-header">
    <div class="container">
      <div class="breadcrumb"><a href="/">Home</a> / Platform Access</div>
      <h1>Platform Access</h1>
      <p>Welcome to the NGnI analysis and project management portal.</p>
    </div>
  </div>

  <section>
    <div class="container">

      <!-- Pre-launch state (default) -->
      <div id="pre-launch" style="max-width:640px;margin:0 auto;text-align:center;">
        <div class="alert alert-info">
          <strong>New session.</strong> Authenticate with your team credentials and press the button below to begin your platform session.
          Your session will be active for <strong>45 minutes</strong>.
        </div>

        <div class="card mt-3" style="text-align:left;">
          <h3>Session Access Code</h3>
          <p class="text-muted" style="font-size:0.9rem;">Enter the access code provided by your session coordinator.</p>
          <div class="form-group">
            <label for="access-code">Access Code</label>
            <input type="password" id="access-code" placeholder="••••••••••••" autocomplete="off" />
          </div>
          <div id="access-code-error" style="display:none;color:#c0392b;font-size:0.85rem;margin-top:0.25rem;">Invalid access code. Please try again.</div>
        </div>

        <div id="team-auth" style="display:none;">
          <div class="card mt-3" style="text-align:left;">
            <h3>Team Authentication</h3>
            <p class="text-muted" style="font-size:0.9rem;">Enter your team name and leader as registered in your session form.</p>
            <div class="form-group">
              <label for="team-name">Team Name</label>
              <input type="text" id="team-name" placeholder="e.g. The Gnome Rangers" />
            </div>
            <div class="form-group">
              <label for="team-leader">Team Leader</label>
              <input type="text" id="team-leader" placeholder="First name" />
            </div>
          </div>

          <button id="launch-btn" class="btn btn-primary mt-3" style="font-size:1.1rem;padding:0.9rem 2.5rem;width:100%;">
            🚀 Initialise Platform Session
          </button>
        </div>

        <button id="verify-btn" class="btn btn-primary mt-3" style="font-size:1.1rem;padding:0.9rem 2.5rem;width:100%;">
          🔑 Verify Access Code
        </button>
      </div>

      <!-- Post-launch state (hidden until button press) -->
      <div id="post-launch" style="display:none;max-width:800px;margin:0 auto;">
        <div class="alert alert-success">
          ✅ <strong>Session active.</strong> Welcome, <span id="display-team"></span>! Your 45-minute session has started.
        </div>

        <div class="cards mt-3">
          <a href="/platform/species-id/" class="card" style="text-decoration:none;cursor:pointer;">
            <div class="card-icon">🔬</div>
            <h3>Species Identification Tool</h3>
            <p>Identify an unknown specimen using our phylogenetic distance classifier. Required for all new gnomics projects.</p>
            <span class="btn btn-outline" style="font-size:0.85rem;padding:0.4rem 0.9rem;">Open Tool →</span>
          </a>
          <div class="card" style="opacity:0.5;">
            <div class="card-icon">📋</div>
            <h3>Project Submission</h3>
            <p>Submit a new sequencing project. Available after species identification is complete.</p>
            <span class="btn btn-outline" style="font-size:0.85rem;padding:0.4rem 0.9rem;cursor:not-allowed;">Locked</span>
          </div>
          <div class="card" style="opacity:0.5;">
            <div class="card-icon">📊</div>
            <h3>Analysis Dashboard</h3>
            <p>View results and download processed data for your projects.</p>
            <span class="btn btn-outline" style="font-size:0.85rem;padding:0.4rem 0.9rem;cursor:not-allowed;">Locked</span>
          </div>
        </div>
      </div>

    </div>
  </section>

</Layout>

<script>
  const H = ['06770edea421d96182c10ddc3dc192c2a4ac39c05670beb3738e38a43b300d37',
             '8a88a25603494bf72ac434a30f32fd8143e0bdc18509b888ed7ef917b2bf3610'];
  const M = ['online', 'mixed'];

  const launchBtn = document.getElementById('launch-btn');
  const verifyBtn = document.getElementById('verify-btn');
  const preLaunch = document.getElementById('pre-launch');
  const postLaunch = document.getElementById('post-launch');
  const displayTeam = document.getElementById('display-team');
  const teamAuth = document.getElementById('team-auth');
  const codeError = document.getElementById('access-code-error');

  // Restore session if already started
  const existingStart = localStorage.getItem('gnomics_start');
  if (existingStart) {
    const teamName = localStorage.getItem('gnomics_team') || 'your team';
    preLaunch!.style.display = 'none';
    postLaunch!.style.display = 'block';
    displayTeam!.textContent = teamName;
    if (localStorage.getItem('gnomics_species_done')) unlockCards();
  }

  async function sha256(str: string): Promise<string> {
    const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(str));
    return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2,'0')).join('');
  }

  verifyBtn?.addEventListener('click', async () => {
    const code = (document.getElementById('access-code') as HTMLInputElement)?.value.trim();
    if (!code) return;
    const hash = await sha256(code);
    const idx = H.indexOf(hash);
    if (idx === -1) {
      codeError!.style.display = 'block';
      return;
    }
    codeError!.style.display = 'none';
    localStorage.setItem('gnomics_mode', M[idx]);
    teamAuth!.style.display = 'block';
    verifyBtn!.style.display = 'none';
    (document.getElementById('access-code') as HTMLInputElement).disabled = true;
  });

  launchBtn?.addEventListener('click', () => {
    const teamName = (document.getElementById('team-name') as HTMLInputElement)?.value.trim();
    const teamLeader = (document.getElementById('team-leader') as HTMLInputElement)?.value.trim();
    if (!teamName || !teamLeader) {
      alert('Please enter your team name and leader before starting.');
      return;
    }
    localStorage.setItem('gnomics_start', String(Date.now()));
    localStorage.setItem('gnomics_team', teamName);
    localStorage.setItem('gnomics_leader', teamLeader);
    preLaunch!.style.display = 'none';
    postLaunch!.style.display = 'block';
    displayTeam!.textContent = teamName;
    window.dispatchEvent(new Event('gnomics_started'));
    location.reload();
  });

  function unlockCards() {
    const cards = document.querySelectorAll('#post-launch .card');
    cards.forEach((card, i) => {
      if (i === 1) {
        (card as HTMLElement).style.opacity = '1';
        const link = card.querySelector('a') ?? card;
        (card as HTMLElement).style.cursor = 'pointer';
        (card as HTMLElement).onclick = () => { window.location.href = '/platform/submit/'; };
        const btn = card.querySelector('.btn') as HTMLElement;
        if (btn) { btn.textContent = 'Open Tool →'; btn.style.cursor = 'pointer'; }
      }
    });
  }
</script>
