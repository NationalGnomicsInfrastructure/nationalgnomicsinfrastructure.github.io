---
import Layout from "../../../layouts/Layout.astro";
---

<Layout title="Pharmagnomics">
    <div class="page-header">
        <div class="container">
            <div class="breadcrumb">
                <a href="/">Home</a> / <a href="/applications/">Applications</a> /
                Pharmagnomics
            </div>
            <h1>Pharmagnomics</h1>
            <p>
                Genotype–phenotype association studies and variant calling for
                gnome drug-response research.
            </p>
        </div>
    </div>
    <section>
        <div class="container" style="max-width:760px;">
            <div class="cards mb-2">
                <div class="card">
                    <div class="card-icon">💊</div><h3>Drug–Gnome Interaction</h3><p>
                        Variant calling and pharmacogenomic panel sequencing for
                        gnome drug-metabolism profiling.
                    </p>
                </div>
                <div class="card">
                    <div class="card-icon">🧪</div><h3>ToxicoGnomics</h3><p>
                        Transcriptomic and epigenomic responses of gnome models
                        to pharmaceutical and environmental toxins.
                    </p>
                </div>
                <div class="card">
                    <div class="card-icon">🎯</div><h3>PharmacoGWAS</h3><p>
                        Genome-wide association studies linking gnome genetic
                        variation to drug efficacy and adverse events.
                    </p>
                </div>
                <div class="card">
                    <div class="card-icon">⚕️</div><h3>Personalised Gnomics</h3><p>
                        Integration of gnomic, epigenomic and clinical data for
                        precision medicine and tailored therapies.
                    </p>
                </div>
            </div>
        </div>
    </section>
</Layout>
