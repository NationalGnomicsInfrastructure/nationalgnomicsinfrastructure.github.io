---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Home">
    <!-- Hero -->
    <section class="hero">
        <div class="container">
            <div
                style="display:flex;align-items:center;gap:2rem;justify-content:center;flex-wrap:wrap;"
            >
                <img
                    src="/ngni-logo.png"
                    alt="NGnI logo"
                    style="height:12rem;flex-shrink:0;"
                />
                <div style="text-align:left;">
                    <h1>National Gnomics Infrastructure</h1>
                    <p>
                        We provide access to cutting-edge gnomics technologies
                        and bioinformatics support to researchers across
                        Listenbourg and beyond.
                    </p>
                    <div style="display:flex;gap:1rem;flex-wrap:wrap;">
                        <a href="/applications/" class="btn btn-secondary"
                            >Applications</a
                        >
                        <a href="/technologies/" class="btn btn-secondary"
                            >Technologies</a
                        >
                        <a href="/database/" class="btn btn-secondary"
                            >Database</a
                        >
                        <a href="/platform/" class="btn btn-secondary"
                            >Platform</a
                        >
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats -->
    <div class="stats">
        <div class="stats-inner">
            <div class="stat">
                <div class="num">3</div><div class="lbl">Core Platforms</div>
            </div>
            <div class="stat">
                <div class="num">47</div><div class="lbl">Active Projects</div>
            </div>
            <div class="stat">
                <div class="num">12</div><div class="lbl">
                    Partner Institutions
                </div>
            </div>
            <div class="stat">
                <div class="num">2026</div><div class="lbl">Founded</div>
            </div>
        </div>
    </div>

    <!-- News -->
    <section>
        <div class="container">
            <div class="section-header">
                <h2>Latest News</h2>
            </div>
            <div class="cards">
                <div class="card">
                    <span class="tag">New</span>
                    <h3 style="margin-top:0.5rem">NGnI OpenLab Launch</h3>
                    <p>
                        Our new collaborative gnomics lab is now open, providing
                        direct access to QC equipment and walk-up sequencing.
                    </p>
                    <small class="text-muted">May 2026</small>
                </div>
                <div class="card">
                    <span class="tag">Technology</span>
                    <h3 style="margin-top:0.5rem">GnomePore P2 Available</h3>
                    <p>
                        Ultra-long gnome reads are now available through our
                        GnomePore P2 instrument — ideal for repeat-rich gnome
                        regions.
                    </p>
                    <small class="text-muted">April 2026</small>
                </div>
                <div class="card">
                    <span class="tag">Pipeline</span>
                    <h3 style="margin-top:0.5rem">gnomics-pipeline v2.0</h3>
                    <p>
                        Major release of our core analysis pipeline. Check the <a
                            href="https://github.com/NationalGnomicsInfrastructure/gnomics-pipeline"
                            >repository</a
                        > for the full changelog.
                    </p>
                    <small class="text-muted">March 2026</small>
                </div>
            </div>
        </div>
    </section>
</Layout>
