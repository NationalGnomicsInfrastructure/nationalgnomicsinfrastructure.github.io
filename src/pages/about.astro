---
import Layout from '../layouts/Layout.astro';
---
<Layout title="About">
  <div class="page-header">
    <div class="container">
      <h1>About NGnI</h1>
      <p>The National Gnomics Infrastructure — part of SciFiLab.</p>
    </div>
  </div>
  <section>
    <div class="container">
      <div>
        <h2>Our Mission</h2>
        <p>
          The National Gnomics Infrastructure (NGnI) provides state-of-the-art gnomics technologies and bioinformatics
          expertise to researchers across Listenbourg and beyond. We are hosted at SciFiLab and serve as a national resource for
          gnome-scale sequencing, spatial gnomics, and ancient gnomics.
        </p>
      </div>
      <h2 class="mt-3">Our Teams</h2>
      <div class="cards mt-2">
        <div class="card">
          <div class="card-icon">🧬</div>
          <h3>Analysis Area</h3>
          <p>Bioinformatics pipelines, data processing and gnome-scale computational analysis for all NGnI projects.</p>
        </div>
        <div class="card">
          <div class="card-icon">🔧</div>
          <h3>Development Area</h3>
          <p>Platform engineering, tool development and infrastructure to keep the gnomics ecosystem running smoothly.</p>
        </div>
        <div class="card">
          <div class="card-icon">🌀</div>
          <h3>Chaos Area</h3>
          <p>Experimental protocols, cutting-edge research and the occasional controlled explosion in the name of gnomics.</p>
        </div>
      </div>
      <div style="max-width:720px;margin:0 auto;">
        <h2 class="mt-4" id="contact">Contact</h2>
        <p>Have a project enquiry or question? Fill in the form below and we'll get back to you.</p>
        <form class="submit-form mt-2" id="contact-form" novalidate>
          <div class="form-group">
            <label for="cf-name">Name</label>
            <input type="text" id="cf-name" name="name" placeholder="Your name" required />
          </div>
          <div class="form-group">
            <label for="cf-email">Email</label>
            <input type="email" id="cf-email" name="email" placeholder="your@email.com" required />
          </div>
          <div class="form-group">
            <label for="cf-subject">Subject</label>
            <select id="cf-subject" name="subject">
              <option value="">— Select a topic —</option>
              <option>Project enquiry</option>
              <option>Technical support</option>
              <option>Partnership</option>
              <option>Other</option>
            </select>
          </div>
          <div class="form-group">
            <label for="cf-message">Message</label>
            <textarea id="cf-message" name="message" rows="5" placeholder="Tell us about your project or question…" required></textarea>
          </div>
          <button type="submit" class="btn btn-primary">Send message</button>
          <p id="cf-feedback" style="margin-top:1rem;display:none;"></p>
        </form>
        <script>
          document.getElementById('contact-form')?.addEventListener('submit', function(e) {
            e.preventDefault();
            const feedback = document.getElementById('cf-feedback') as HTMLElement | null;
            if (feedback) {
              feedback.style.display = 'block';
              feedback.style.color = '#c0392b';
              feedback.textContent = '🧚 Delivery failed: the magical creatures responsible for mail delivery are currently on strike. Please try again after the dispute is resolved.';
            }
          });
        </script>
      </div>
    </div>
  </section>
</Layout>
