// ─── Taxonomy ─────────────────────────────────────────────────────────────────
// clade: 0 = Invertebrata, 1 = Vertebrata (non-mammal), 2 = Mammalia (non-rodent),
//        3 = Rodentia (non-caviid), 4 = Caviidae, 5 = target (correct)
const TAXONOMY: Record<string, { clade: number; label: string }> = {
