---
import Layout from "../../../layouts/Layout.astro";
---

<Layout title="Mycognomics">
    <div class="page-header">
        <div class="container">
            <div class="breadcrumb">
                <a href="/">Home</a> / <a href="/applications/">Applications</a> /
                Mycognomics
            </div>
            <h1>Mycognomics</h1>
            <p>
                Fungal community profiling and single-gnome sequencing from
                forest and grassland habitats.
            </p>
        </div>
    </div>
    <section>
        <div class="container" style="max-width:760px;">
            <div class="cards mb-2">
                <div class="card">
                    <div class="card-icon">🍄</div><h3>Fungal Metagnomics</h3><p>
                        Amplicon and shotgun metagnomic profiling of fungal
                        communities from soil and rhizosphere samples.
                    </p>
                </div>
                <div class="card">
                    <div class="card-icon">🧬</div><h3>Single-Spore Gnomics</h3><p>
                        Whole-gnome sequencing of individual fungal spores for
                        population genetics and strain identification.
                    </p>
                </div>
                <div class="card">
                    <div class="card-icon">🌲</div><h3>Mycorrhizal Networks</h3><p>
                        Characterisation of symbiotic fungal networks and their
                        gnomic diversity across forest ecosystems.
                    </p>
                </div>
                <div class="card">
                    <div class="card-icon">🔬</div><h3>Hyphal Transcriptomics</h3><p>
                        Gene expression profiling of fungal hyphae under diverse
                        environmental and stress conditions.
                    </p>
                </div>
            </div>
        </div>
    </section>
</Layout>
