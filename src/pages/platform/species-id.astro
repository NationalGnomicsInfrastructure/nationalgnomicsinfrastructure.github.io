  'mole':                { path: ['bilateria','deuterostomia','chordata','vertebrata','tetrapoda','amniota','mammalia','talpidae'],       display: 'Talpidae' },
  'kangaroo':            { path: ['bilateria','deuterostomia','chordata','vertebrata','tetrapoda','amniota','mammalia','marsupialia'],    display: 'Marsupialia' },
  'koala':               { path: ['bilateria','deuterostomia','chordata','vertebrata','tetrapoda','amniota','mammalia','marsupialia'],    display: 'Marsupialia' },
  // ─── Target species (included so they appear in autocomplete for other targets) ───
  'capybara':            { path: ['bilateria','deuterostomia','chordata','vertebrata','tetrapoda','amniota','mammalia','rodentia','caviidae'],                display: 'Caviidae' },
  'cat':                 { path: ['bilateria','deuterostomia','chordata','vertebrata','tetrapoda','amniota','mammalia','carnivora','felidae'],                 display: 'Felidae' },
  'red-eyed tree frog':  { path: ['bilateria','deuterostomia','chordata','vertebrata','tetrapoda','amphibia','anura','hylidae'],                             display: 'Hylidae' },
  'cicada':              { path: ['bilateria','protostomia','ecdysozoa','arthropoda','insecta','pterygota','hemiptera','cicadidae'],                          display: 'Cicadidae' },
};

// ─── Possible Targets ─────────────────────────────────────────────────────────
type TargetConfig = {
  name: string; scientific: string; emoji: string;
  path: string[];    // 8 phylogenetic group IDs (Bilateria → family)
  labels: string[];  // display labels for each path node
  others: string[];  // "other branch" label shown as sibling at each tree level
  descs: string[];   // clade description shown in the panel (index 0–8)
};

const POSSIBLE_TARGETS: TargetConfig[] = [
  {
    name: 'capybara', scientific: 'Hydrochoerus hydrochaeris', emoji: '🦫',
    path:   ['bilateria','deuterostomia','chordata','vertebrata','amniota','mammalia','rodentia','caviidae'],
    labels: ['Bilateria','Deuterostomia','Chordata','Vertebrata','Amniota','Mammalia','Rodentia','Caviidae'],
    others: ['Non-Bilateria','Protostomia','Other Deuterostomia','Other Chordata','Other Vertebrata','Other Amniota','Other Mammalia','Other Rodentia'],
    descs: [
      '🥶 <strong>Non-Bilateria</strong> — Sponges, jellyfish, corals. No bilateral symmetry.',
      '🧊 <strong>Bilateria — Protostomia</strong> — Wrong branch. Molluscs, arthropods, annelids.',
      '🧊 <strong>Deuterostomia — non-Chordata</strong> — Echinoderms: starfish, sea urchins.',
      '❄️ <strong>Chordata — non-Vertebrata</strong> — Lancelets and tunicates.',
      '❄️ <strong>Vertebrata — non-Amniota</strong> — Fish and amphibians.',
      '🌤️ <strong>Amniota — non-Mammalia</strong> — Reptiles and birds.',
      '🌤️ <strong>Mammalia — non-Rodentia</strong> — Warm-blooded, milk-producing, but not a rodent.',
      '🌡️ <strong>Rodentia — non-Caviidae</strong> — Gnawing mammals, but not in the cavy family.',
      '🔥 <strong>Caviidae</strong> — South American cavy rodents: guinea pigs, maras, and their relatives. Very close!',
    ],
  },
  {
    name: 'cat', scientific: 'Felis catus', emoji: '🐱',
    path:   ['bilateria','deuterostomia','chordata','vertebrata','amniota','mammalia','carnivora','felidae'],
    labels: ['Bilateria','Deuterostomia','Chordata','Vertebrata','Amniota','Mammalia','Carnivora','Felidae'],
    others: ['Non-Bilateria','Protostomia','Other Deuterostomia','Other Chordata','Other Vertebrata','Other Amniota','Other Mammalia','Other Carnivora'],
    descs: [
      '🥶 <strong>Non-Bilateria</strong> — Sponges, jellyfish, corals. No bilateral symmetry.',
      '🧊 <strong>Bilateria — Protostomia</strong> — Wrong branch. Molluscs, arthropods, annelids.',
      '🧊 <strong>Deuterostomia — non-Chordata</strong> — Echinoderms: starfish, sea urchins.',
      '❄️ <strong>Chordata — non-Vertebrata</strong> — Lancelets and tunicates.',
      '❄️ <strong>Vertebrata — non-Amniota</strong> — Fish and amphibians.',
      '🌤️ <strong>Amniota — non-Mammalia</strong> — Reptiles and birds.',
      '🌤️ <strong>Mammalia — non-Carnivora</strong> — Mammals, but not an order Carnivora member.',
      '🌡️ <strong>Carnivora — non-Felidae</strong> — Dogs, bears, weasels — not the cat family.',
      '🔥 <strong>Felidae</strong> — The cat family: lions, tigers, leopards. Very close!',
    ],
  },
  {
    name: 'red-eyed tree frog', scientific: 'Agalychnis callidryas', emoji: '🐸',
    path:   ['bilateria','deuterostomia','chordata','vertebrata','tetrapoda','amphibia','anura','hylidae'],
    labels: ['Bilateria','Deuterostomia','Chordata','Vertebrata','Tetrapoda','Amphibia','Anura','Hylidae'],
    others: ['Non-Bilateria','Protostomia','Other Deuterostomia','Other Chordata','Other Vertebrata (fish)','Amniota','Other Amphibia','Other Anura'],
    descs: [
      '🥶 <strong>Non-Bilateria</strong> — Sponges, jellyfish, corals. No bilateral symmetry.',
      '🧊 <strong>Bilateria — Protostomia</strong> — Wrong branch. Molluscs, arthropods, annelids.',
      '🧊 <strong>Deuterostomia — non-Chordata</strong> — Echinoderms: starfish, sea urchins.',
      '❄️ <strong>Chordata — non-Vertebrata</strong> — Lancelets and tunicates.',
      '❄️ <strong>Vertebrata — non-Tetrapoda</strong> — Fish (jawless, cartilaginous, bony).',
      '🌤️ <strong>Tetrapoda — Amniota</strong> — Four-limbed vertebrates on the wrong branch: reptiles, birds, mammals.',
      '🌤️ <strong>Amphibia — non-Anura</strong> — Salamanders, newts, axolotls.',
      '🌡️ <strong>Anura — non-Hylidae</strong> — Frogs and toads, but not the tree frog family.',
      '🔥 <strong>Hylidae</strong> — Tree frogs! Very close.',
    ],
  },
  {
    name: 'cicada', scientific: 'Magicicada septendecim', emoji: '🦗',
    path:   ['bilateria','protostomia','ecdysozoa','arthropoda','insecta','pterygota','hemiptera','cicadidae'],
    labels: ['Bilateria','Protostomia','Ecdysozoa','Arthropoda','Insecta','Pterygota','Hemiptera','Cicadidae'],
    others: ['Non-Bilateria','Deuterostomia','Lophotrochozoa','Other Ecdysozoa','Other Arthropoda','Apterygota','Other Pterygota','Other Hemiptera'],
    descs: [
      '🥶 <strong>Non-Bilateria</strong> — Sponges, jellyfish, corals. No bilateral symmetry.',
      '🧊 <strong>Bilateria — Deuterostomia</strong> — Wrong branch. Vertebrates and echinoderms.',
      '🧊 <strong>Protostomia — Lophotrochozoa</strong> — Wrong subgroup. Molluscs and annelids.',
      '❄️ <strong>Ecdysozoa — non-Arthropoda</strong> — Moulting animals without jointed legs. Nematodes, tardigrades.',
      '❄️ <strong>Arthropoda — non-Insecta</strong> — Jointed legs, but not insects. Spiders, crabs, centipedes.',
