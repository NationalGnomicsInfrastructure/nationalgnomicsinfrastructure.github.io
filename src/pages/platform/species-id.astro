  'bat':                 { path: ['bilateria','deuterostomia','chordata','vertebrata','tetrapoda','amniota','mammalia','chiroptera'],     display: 'Chiroptera' },
  'hedgehog':            { path: ['bilateria','deuterostomia','chordata','vertebrata','tetrapoda','amniota','mammalia','erinaceidae'],    display: 'Erinaceidae' },
  'mole':                { path: ['bilateria','deuterostomia','chordata','vertebrata','tetrapoda','amniota','mammalia','talpidae'],       display: 'Talpidae' },
  'kangaroo':            { path: ['bilateria','deuterostomia','chordata','vertebrata','tetrapoda','amniota','mammalia','marsupialia'],    display: 'Marsupialia' },
  'koala':               { path: ['bilateria','deuterostomia','chordata','vertebrata','tetrapoda','amniota','mammalia','marsupialia'],    display: 'Marsupialia' },
  // ─── Target species (included so they appear in autocomplete for other targets) ───
  'capybara':            { path: ['bilateria','deuterostomia','chordata','vertebrata','tetrapoda','amniota','mammalia','rodentia','caviidae'],                display: 'Caviidae' },
  'cat':                 { path: ['bilateria','deuterostomia','chordata','vertebrata','tetrapoda','amniota','mammalia','carnivora','felidae'],                 display: 'Felidae' },
  'red-eyed tree frog':  { path: ['bilateria','deuterostomia','chordata','vertebrata','tetrapoda','amphibia','anura','hylidae'],                             display: 'Hylidae' },
  'cicada':              { path: ['bilateria','protostomia','ecdysozoa','arthropoda','insecta','pterygota','hemiptera','cicadidae'],                          display: 'Cicadidae' },
};

// ─── Possible Targets (base64-encoded to avoid spoilers in source) ────────────
type TargetConfig = {
  name: string; scientific: string;
  path: string[];    // 8 phylogenetic group IDs (Bilateria → family)
  labels: string[];  // display labels for each path node
};

const ENCODED_TARGETS: string[] = [
  '',
  '',
  '',
  '',
];
const POSSIBLE_TARGETS: TargetConfig[] = ENCODED_TARGETS.map(s => JSON.parse(decodeURIComponent(escape(atob(s)))));

// ─── Select or restore target ─────────────────────────────────────────────────
let targetIdx = parseInt(localStorage.getItem('gnomics_target') ?? '');
if (isNaN(targetIdx) || targetIdx < 0 || targetIdx >= POSSIBLE_TARGETS.length) {
  targetIdx = Math.floor(Math.random() * POSSIBLE_TARGETS.length);
  localStorage.setItem('gnomics_target', String(targetIdx));
}
const TARGET = POSSIBLE_TARGETS[targetIdx];
const CORRECT_CLADE = TARGET.path.length + 1; // 9

// ─── Compute taxonomy dynamically ─────────────────────────────────────────────
// For each species, find the deepest path node it shares with the target (in order).
const WARMTH_ICON = ['🥶','🧊','🧊','❄️','❄️','🌤️','🌤️','🌡️','🔥'];
const WARMTH_WORD = ['Very cold','Cold','Cold','Cool','Cool','Warm','Warm','Hot','Very hot'];

const TAXONOMY: Record<string, { clade: number; label: string }> = {};
for (const [species, data] of Object.entries(SPECIES_DB)) {
  if (species === TARGET.name) {
    TAXONOMY[species] = { clade: CORRECT_CLADE, label: '✅ Correct!' };
    continue;
  }
  let clade = 0;
  for (let i = 0; i < TARGET.path.length; i++) {
    if (data.path.includes(TARGET.path[i])) {
      clade = i + 1;
    } else {
      break;
    }
  }
  const pathLabel = clade > 0 ? TARGET.labels[clade - 1] : 'Non-Bilateria';
  const icon = WARMTH_ICON[clade] ?? '🧊';
  const word = WARMTH_WORD[clade] ?? 'Cold';
  TAXONOMY[species] = { clade, label: `${icon} ${word} — ${pathLabel} (${data.display})` };
}

// ─── Derive node/branch/subtree IDs from the chosen target's path ────────────
const CLADE_NODE:    Record<number, string> = { 0: 'node-metazoa' };
const CLADE_BRANCH:  Record<number, string> = { 0: 'branch-metazoa' };
const CLADE_SUBTREE: Record<number, string> = {};
TARGET.path.forEach((id, i) => {
  CLADE_NODE[i + 1]    = `node-${id}`;
  CLADE_BRANCH[i + 1]  = `branch-${id}`;
  CLADE_SUBTREE[i + 1] = `subtree-${id}`;
});

const CLADE_CLASS: Record<number, string> = {
  0: 'hint-cold', 1: 'hint-cold', 2: 'hint-cold', 3: 'hint-cold',
  4: 'hint-cold', 5: 'hint-warm', 6: 'hint-warm', 7: 'hint-hot', 8: 'hint-hot',
};

// ─── Build phylogenomic tree HTML dynamically ─────────────────────────────────
function buildTree(): void {
  // Each path node is wrapped in a hidden subtree-{id} div; revealed on guess.
  function buildFromDepth(depth: number): string {
    if (depth >= TARGET.path.length) return '';
    const id    = TARGET.path[depth];
    const label = TARGET.labels[depth];
    return `
      <div class="phylo-subtree" id="subtree-${id}" style="display:none">
        <div class="phylo-node" id="node-${id}">${label}</div>
        <div class="phylo-branch" id="branch-${id}" style="display:none">
          ${buildFromDepth(depth + 1)}
        </div>
      </div>`;
  }

  const container = document.getElementById('phylo-tree')!;
  // Metazoa is always visible + green; its branch is always open so ??? starts inside.
  container.innerHTML = `
    <div class="phylo-node phylo-node-hit" id="node-metazoa">Metazoa</div>
    <div class="phylo-branch" id="branch-metazoa">
      ${buildFromDepth(0)}
    </div>`;

  // ??? placeholder starts inside branch-metazoa (visible from the start).
  const targetSubtree = document.createElement('div');
  targetSubtree.className = 'phylo-subtree';
  targetSubtree.id = 'target-subtree';
  targetSubtree.innerHTML = '<div class="phylo-node phylo-target" id="node-target">???</div>';
  document.getElementById('branch-metazoa')!.appendChild(targetSubtree);
}
buildTree();

// Move ??? to the deepest open branch; only ever moves deeper, never back.
// clade=0 → branch-metazoa (initial position, no-op); clade=N → CLADE_BRANCH[N].
let maxCladeSeen = 0;
function moveTargetPlaceholder(clade: number) {
  const effectiveClade = Math.min(clade, TARGET.path.length);
  if (effectiveClade <= maxCladeSeen) return;
  maxCladeSeen = effectiveClade;
  const branch = document.getElementById(CLADE_BRANCH[effectiveClade]);
  if (branch) branch.appendChild(document.getElementById('target-subtree')!);
}

// ─── DOM references ───────────────────────────────────────────────────────────
const MAX_GUESSES = 20;
let guessesLeft = MAX_GUESSES;

const input        = document.getElementById('species-input') as HTMLInputElement;
const datalist     = document.getElementById('species-list') as HTMLDataListElement;
const btn          = document.getElementById('guess-btn') as HTMLButtonElement;
const list         = document.getElementById('guess-list') as HTMLUListElement;
const guessesLabel = document.getElementById('guesses-left') as HTMLSpanElement;
const gameArea     = document.getElementById('game-area') as HTMLDivElement;
const successArea  = document.getElementById('success-area') as HTMLDivElement;
const failArea     = document.getElementById('fail-area') as HTMLDivElement;
const retryBtn     = document.getElementById('retry-btn') as HTMLButtonElement;

// Populate success/fail target name
const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
(document.getElementById('success-name') as HTMLElement).textContent = cap(TARGET.name);
(document.getElementById('success-scientific') as HTMLElement).textContent = TARGET.scientific;
(document.getElementById('fail-name') as HTMLElement).textContent = cap(TARGET.name);
(document.getElementById('fail-scientific') as HTMLElement).textContent = TARGET.scientific;

// Autocomplete: sorted, shown only when letters are typed
const ALL_SPECIES = Object.keys(TAXONOMY).map(cap).sort();

function updateDatalist(query: string) {
  datalist.innerHTML = '';
  if (!query) return;
  const q = query.toLowerCase();
  ALL_SPECIES.filter(n => n.toLowerCase().startsWith(q)).forEach(n => {
    const opt = document.createElement('option');
    opt.value = n;
    datalist.appendChild(opt);
  });
}
input.addEventListener('input', () => {
  const val = input.value.trim();
  updateDatalist(val);
  // Auto-submit when an exact taxonomy match is selected (e.g. from datalist click)
  if (val && TAXONOMY[val.toLowerCase()]) {
    setTimeout(submitGuess, 50);
  }
});

// Restore if already done
if (localStorage.getItem('gnomics_species_done')) {
  gameArea.style.display = 'none';
  successArea.style.display = 'block';
}

// Build a nested wrong-path subtree (all nodes red) ending with the species name.
function buildWrongSubtree(species: string, wrongPath: string[]): string {
  function inner(idx: number): string {
    if (idx >= wrongPath.length) {
      return `<div class="phylo-node phylo-node-miss phylo-target">${cap(species)}</div>`;
    }
    return `<div class="phylo-subtree">
      <div class="phylo-node phylo-node-miss">${cap(wrongPath[idx])}</div>
      <div class="phylo-branch">${inner(idx + 1)}</div>
    </div>`;
  }
  return inner(0);
}

function highlightNode(clade: number, raw: string) {
  // Reveal + green all shared ancestors (c=1..clade), opening each subtree and branch.
  for (let c = 1; c <= clade; c++) {
    const subtreeEl = document.getElementById(CLADE_SUBTREE[c]);
    if (subtreeEl) subtreeEl.style.display = '';
    const nodeEl = document.getElementById(CLADE_NODE[c]);
    if (nodeEl) { nodeEl.classList.remove('phylo-node-miss'); nodeEl.classList.add('phylo-node-hit'); }
    const branchEl = document.getElementById(CLADE_BRANCH[c]);
    if (branchEl) branchEl.style.display = '';
  }
  // Add full wrong-path subtree in the divergence branch.
  const divBranch = document.getElementById(CLADE_BRANCH[clade]);
  if (divBranch) {
    divBranch.style.display = '';
    if (!divBranch.querySelector(`[data-species="${raw}"]`)) {
      // Diverging path = everything in the guess path after the shared prefix.
      const wrongPath = (SPECIES_DB[raw]?.path ?? []).slice(clade);
      const subtree = document.createElement('div');
      subtree.className = 'phylo-subtree';
      subtree.dataset.species = raw;
      subtree.innerHTML = buildWrongSubtree(raw, wrongPath);
      const targetSub = document.getElementById('target-subtree');
      if (targetSub?.parentElement === divBranch) {
        divBranch.insertBefore(subtree, targetSub);
      } else {
        divBranch.appendChild(subtree);
      }
    }
  }
  moveTargetPlaceholder(clade);
}

function updateGuessesLabel() {
  guessesLabel.textContent = `${guessesLeft} guess${guessesLeft === 1 ? '' : 'es'} remaining`;
  guessesLabel.style.color = guessesLeft <= 3 ? '#c0392b' : '';
}
updateGuessesLabel();

function submitGuess() {
  const raw = input.value.trim().toLowerCase();
  if (!raw) return;
  input.value = '';
  updateDatalist('');

  const data = TAXONOMY[raw];
  const li = document.createElement('li');
  li.className = 'guess-row';

  if (!data) {
    li.innerHTML = `<span class="guess-name">${raw}</span><span class="hint-pill hint-cold">Unknown species</span>`;
    list.prepend(li);
    return;
  }

  if (data.clade === CORRECT_CLADE) {
    localStorage.setItem('gnomics_species_done', '1');
    moveTargetPlaceholder(CORRECT_CLADE);
    for (let c = 1; c <= TARGET.path.length; c++) {
      const subtreeEl = document.getElementById(CLADE_SUBTREE[c]);
      if (subtreeEl) subtreeEl.style.display = '';
    }
    for (let c = 0; c <= TARGET.path.length; c++) {
      document.getElementById(CLADE_NODE[c])?.classList.add('phylo-node-hit');
      const el = document.getElementById(CLADE_BRANCH[c]);
      if (el) el.style.display = '';
    }
    const targetNode = document.getElementById('node-target')!;
    targetNode.textContent = cap(TARGET.name);
    targetNode.classList.add('phylo-node-hit', 'phylo-node-correct');
    gameArea.style.display = 'none';
    successArea.style.display = 'block';
    return;
  }

  guessesLeft--;
  updateGuessesLabel();
  highlightNode(data.clade, raw);

  const cls = CLADE_CLASS[data.clade] ?? 'hint-cold';
  li.innerHTML = `<span class="guess-name">${raw}</span><span class="hint-pill ${cls}">${data.label}</span>`;
  list.prepend(li);

  if (guessesLeft === 0) {
    gameArea.style.display = 'none';
    failArea.style.display = 'block';
  }
}

retryBtn?.addEventListener('click', () => {
  localStorage.removeItem('gnomics_target');
  window.location.reload();
});

btn.addEventListener('click', submitGuess);
input.addEventListener('keydown', (e) => { if (e.key === 'Enter') submitGuess(); });
</script>
