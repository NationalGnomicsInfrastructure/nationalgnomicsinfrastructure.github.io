---
import Layout from '../../layouts/Layout.astro';
import '../../styles/species-id.css';
---
<Layout title="Species Identification" showTimer={true}>

  <div class="page-header">
    <div class="container">
      <h1>Species Identification</h1>
      <p>Identify the spirit animal of the Project Coordinator in charge of your delivery project.</p>
    </div>
  </div>

  <section>
    <div class="container">

      <p class="text-muted description-wide" style="font-size:0.95rem;margin-bottom:1.5rem;">
        Each Project Coordinator has a spirit animal. To know which project you are tasked to deliver,
        you must first identify your Project Coordinator — and to do that, you need to find their spirit animal.
      </p>

      <div class="phylo-panel">
        <h4 style="margin-bottom:0.75rem;font-size:0.85rem;text-transform:uppercase;letter-spacing:0.05em;opacity:0.7;">Phylogenomic Tree</h4>
        <div class="phylo-db" id="phylo-db"></div>
      </div>

      <div class="game-bottom">
        <div class="game-controls" id="game-controls">
          <div class="alert alert-info mb-2">
            <strong>Instructions:</strong> Enter animal names below — each guess returns a phylogenetic proximity hint.
            Every name in the tree is linked to its Wikipedia entry.
          </div>
          <datalist id="species-list"></datalist>
          <div class="species-input-row">
            <input type="text" id="species-input" placeholder="Enter a species name…" list="species-list" autocomplete="off" />
            <button class="btn btn-primary" id="guess-btn">Submit</button>
          </div>
        </div>
        <div class="game-guesses">
          <h4 style="margin-bottom:0.75rem;font-size:0.85rem;text-transform:uppercase;letter-spacing:0.05em;opacity:0.7;">
            Guesses <span id="guesses-left" style="font-weight:400;">(0)</span>
          </h4>
          <ul class="guess-history" id="guess-list"></ul>
        </div>
      </div>

      <div id="success-area" style="display:none;" class="success-box">
        <div style="font-size:3rem;">🎉</div>
        <h3>Spirit Animal Identified!</h3>
        <p>The Project Coordinator's spirit animal is a <strong id="success-name"></strong> (<em id="success-scientific"></em>).</p>
        <a href="/platform/" class="btn btn-primary mt-2">Proceed to Next Task →</a>
      </div>

    </div>
  </section>

</Layout>

<script>
import * as d3 from 'd3';
import PHYLO_RAW from '../../data/phylo-db.csv?raw';
import TARGETS_RAW from '../../data/philo-targets.txt?raw';
const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
const SPECIES_DB: string[][] = PHYLO_RAW.trim().split('\n').map(line => line.split(','));

type TargetConfig = { name: string; scientific: string; path: string[] };
const POSSIBLE_TARGETS: TargetConfig[] = TARGETS_RAW.trim().split('\n').map(row => {
  const name = atob(row.trim());
  const entry = SPECIES_DB.find(e => e[e.length - 2] === name)!;
  const scientific = entry[entry.length - 1];
  const path = entry.slice(0, -2);
  return { name, scientific, path };
});


// ─── Select target based on access code ───────────────────────────────────────
const targetIdx = parseInt(localStorage.getItem('code_idx') ?? '');
if (isNaN(targetIdx) || targetIdx < 0 || targetIdx >= POSSIBLE_TARGETS.length) {
  window.location.href = '/platform/';
  throw new Error('No valid access code found — redirecting to platform.');
}
const TARGET = POSSIBLE_TARGETS[targetIdx];
const CORRECT_CLADE = TARGET.path.length + 1; // 9

// ─── Compute taxonomy dynamically ─────────────────────────────────────────────
// For each species, find the deepest path node it shares with the target (in order).
const WARMTH_ICON = ['🥶','🧊','🧊','❄️','❄️','🌤️','🌤️','🌡️','🔥'];
const WARMTH_WORD = ['Very cold','Cold','Cold','Cool','Cool','Warm','Warm','Hot','Very hot'];
const wiki = (term: string) => `https://en.wikipedia.org/wiki/${encodeURIComponent(term.replace(/ /g, '_'))}`;
const wikiLink = (label: string) => `<a href="${wiki(label)}" target="_blank" rel="noopener noreferrer">${label}</a>`;

const TAXONOMY: Record<string, { clade: number; label: string; divergent?: string }> = {};
for (const entry of SPECIES_DB) {
  const species = entry[entry.length - 2];
  if (species === TARGET.name) {
    TAXONOMY[species] = { clade: CORRECT_CLADE, label: '✅ Correct!' };
    continue;
  }
  let clade = 0;
  for (let i = 0; i < TARGET.path.length; i++) {
    if (entry.includes(TARGET.path[i])) {
      clade = i + 1;
    } else {
      break;
    }
  }
  const icon = WARMTH_ICON[clade] ?? '🧊';
  const word = WARMTH_WORD[clade] ?? 'Cold';
  const link = clade > 0 ? wikiLink(cap(TARGET.path[clade - 1])) : wikiLink('Metazoa');
  const divergent = clade > 0 && clade < entry.length - 2 ? cap(entry[clade]) : undefined;
  TAXONOMY[species] = { clade, label: `${icon} ${word} — ${link}`, divergent };
}

// ─── Derive node/branch/subtree IDs from the chosen target's path ────────────
const CLADE_CLASS: Record<number, string> = {
  0: 'hint-cold', 1: 'hint-cold', 2: 'hint-cold', 3: 'hint-cold',
  4: 'hint-cold', 5: 'hint-warm', 6: 'hint-warm', 7: 'hint-hot', 8: 'hint-hot',
};

// ─── Tree state ───────────────────────────────────────────────────────────────
// missAtClade[c]: list of raw species names guessed that diverge at clade c.
const missAtClade = new Map<number, string[]>();

// ─── D3 tree data types ──────────────────────────────────────────
interface D3Node {
  id: string;
  name: string;
  url?: string;
  type: 'hit' | 'miss' | 'miss-clade' | 'target' | 'correct' | 'shared';
  children?: D3Node[];
}
let _idCounter = 0;
function uid(prefix = 'n'): string { return `pn${prefix}${++_idCounter}`; }

// ─── Build D3 tree data from misses ──────────────────────────────
function buildTreeData(): D3Node {
  const cladeLevels = [...missAtClade.keys()].sort((a, b) => a - b);
  const root: D3Node = { id: 'node-root', name: 'Metazoa', url: wiki('Metazoa'), type: 'hit', children: [] };

  if (cladeLevels.length === 0) {
    const targetName = _won ? cap(TARGET.name) : '???';
    const targetUrl = _won ? wiki(TARGET.scientific) : undefined;
    root.children!.push({ id: 'node-target', name: targetName, url: targetUrl, type: _won ? 'correct' : 'target' });
    return root;
  }

  function addMisses(parent: D3Node, level: number) {
    const names = missAtClade.get(level)!;
    const divMap = new Map<string, string[]>();
    for (const n of names) {
      const t = TAXONOMY[n];
      const d = t?.divergent && t.divergent !== cap(n) ? t.divergent : '';
      if (!divMap.has(d)) divMap.set(d, []);
      divMap.get(d)!.push(n);
    }
    for (const [d, members] of divMap) {
      if (d && members.length >= 2) {
        const mc: D3Node = { id: uid(), name: d, url: wiki(d), type: 'miss-clade', children: [] };
        for (const n of members) mc.children!.push({ id: uid(), name: cap(n), url: wiki(cap(n)), type: 'miss' });
        parent.children!.push(mc);
      } else {
        for (const n of members) parent.children!.push({ id: uid(), name: cap(n), url: wiki(cap(n)), type: 'miss' });
      }
    }
  }

  let cur = root;
  for (const clade of cladeLevels) {
    const name = clade > 0 ? cap(TARGET.path[clade - 1]) : '';
    const shared: D3Node = { id: uid(), name, url: name ? wiki(name) : undefined, type: 'shared', children: [] };
    addMisses(shared, clade);
    cur.children!.push(shared);
    cur = shared;
  }

  const targetName = _won ? cap(TARGET.name) : '???';
  const targetUrl = _won ? wiki(TARGET.scientific) : undefined;
  cur.children!.push({ id: 'node-target', name: targetName, url: targetUrl, type: _won ? 'correct' : 'target' });
  return root;
}

let _won = false;
function rebuildTree() {
  const container = document.getElementById('phylo-db')!;
  const data = buildTreeData();

  container.innerHTML = `<div class="phylo-tree" id="T"><svg class="phylo-svg" id="S"></svg></div>`;

  requestAnimationFrame(() => requestAnimationFrame(() => drawD3Tree(data)));
}

function drawD3Tree(root: D3Node) {
  const svgEl = document.getElementById('S') as unknown as SVGSVGElement;
  const T = document.getElementById('T') as HTMLDivElement;
  if (!svgEl || !T) return;

  const hierarchy = d3.hierarchy(root);
  const pointRoot = d3.tree<D3Node>().nodeSize([140, 60])(hierarchy);

  // Push target node to the bottom of the tree
  let maxNonTargetY = 0;
  pointRoot.each(d => { if (d.data.id !== 'node-target' && d.y > maxNonTargetY) maxNonTargetY = d.y; });
  pointRoot.each(d => { if (d.data.id === 'node-target') d.y = maxNonTargetY + 60; });

  // Recompute bounds after moving target
  let minX = Infinity, maxX = -Infinity, minY = Infinity, maxY = -Infinity;
  pointRoot.each(d => {
    if (d.x < minX) minX = d.x;
    if (d.x > maxX) maxX = d.x;
    if (d.y < minY) minY = d.y;
    if (d.y > maxY) maxY = d.y;
  });

  // Position target at bottom of panel with minimal gap
  const panel = T.closest('.phylo-panel');
  const panelH = panel ? panel.clientHeight : 400;
  const topPad = 15;
  const botPad = 15;
  const gap = 25;
  const minH = 300;
  const cH = Math.max(panelH, minH, maxY + botPad + gap);

  // Scale non-target y positions to fit between topPad and (targetY - gap)
  const targetNode = pointRoot.find(d => d.data.id === 'node-target');
  const targetY = cH - botPad;
  if (targetNode) targetNode.y = targetY;
  const d3Span = maxNonTargetY - minY || 1;
  const availY = targetY - topPad - gap;
  pointRoot.each(d => {
    if (d.data.id !== 'node-target') {
      d.y = topPad + ((d.y - minY) / d3Span) * availY;
    }
  });

  // Final bounds
  minX = Infinity; maxX = -Infinity; minY = Infinity; maxY = -Infinity;
  pointRoot.each(d => {
    if (d.x < minX) minX = d.x;
    if (d.x > maxX) maxX = d.x;
    if (d.y < minY) minY = d.y;
    if (d.y > maxY) maxY = d.y;
  });

  const panelWidth = T.parentElement?.clientWidth ?? 280;
  const pad = 20;
  const cw = Math.max(panelWidth, maxX - minX + pad * 2);
  const xOff = cw / 2 - (minX + maxX) / 2;

  pointRoot.each(d => { d.x += xOff; });

  // Align spine nodes (last-child chain) to panel center
  const spineIds = new Set<string>();
  for (let s: (typeof pointRoot) | null = pointRoot; s; s = s.children?.length ? s.children[s.children.length - 1] : null) {
    spineIds.add(s.data.id);
  }
  const centerX = cw / 2;
  pointRoot.each(d => { if (spineIds.has(d.data.id)) d.x = centerX; });

  // Distribute side-branch children around the spine with no overlap
  pointRoot.each(d => {
    if (!spineIds.has(d.data.id) || !d.children || d.children.length < 2) return;
    const lastI = d.children.length - 1;
    const base = 80;
    const step = 70;
    for (let i = 0; i < lastI; i++) {
      const side = i % 2 === 0 ? -1 : 1;
      const off = base + Math.floor(i / 2) * step;
      const newX = d.x + side * off;
      const dx = newX - d.children[i].x;
      d.children[i].each((desc: any) => { desc.x += dx; });
    }
  });

  // Ensure children of non-spine nodes stay on the same side (away from spine)
  pointRoot.each(d => {
    if (spineIds.has(d.data.id) || !d.children) return;
    const isLeft = d.x < centerX;
    const base = 80;
    const step = 70;
    for (let i = 0; i < d.children.length; i++) {
      const off = base + i * step;
      d.children[i].x = d.x + (isLeft ? -off : off);
    }
  });

  const svg = d3.select(svgEl);
  svg.attr('viewBox', `0 0 ${cw} ${cH}`)
     .attr('width', cw)
     .attr('height', cH);

  T.style.width = `${cw}px`;
  T.style.height = `${cH}px`;

  // Draw links (from bottom of parent rect to top of child rect)
  svg.selectAll('.phylo-link')
    .data(pointRoot.links())
    .join('path')
    .attr('class', 'phylo-link')
    .attr('d', (d: any) => {
      const s = d.source, t = d.target;
      const sy = s.y + 11, ty = t.y - 11;
      const my = Math.max(sy, ty - 15);
      return `M${s.x},${sy}C${s.x},${my} ${t.x},${my} ${t.x},${ty}`;
    })
    .attr('fill', 'none')
    .attr('stroke', '#999')
    .attr('stroke-width', 2);

  // Draw nodes
  const nodeGroups = svg.selectAll('.phylo-svg-node')
    .data(pointRoot.descendants())
    .join('g')
    .attr('class', d => `phylo-svg-node phylo-svg-node-${d.data.type}`)
    .attr('transform', d => `translate(${d.x},${d.y})`);

  nodeGroups.each(function(d) {
    const group = d3.select(this);
    const el = d.data.url
      ? group.append('a').attr('href', d.data.url).attr('target', '_blank').attr('rel', 'noopener noreferrer')
      : group;
    const bw = d.data.name.length * 7.5 + 14;
    el.append('rect').attr('x', -bw / 2).attr('y', -11).attr('width', bw).attr('height', 22).attr('rx', 4);
    el.append('text').text(d.data.name);
  });
}

rebuildTree();

function highlightNode(clade: number, raw: string) {
  if (!missAtClade.has(clade)) missAtClade.set(clade, []);
  const existing = missAtClade.get(clade)!;
  if (!existing.includes(raw)) existing.push(raw);
  rebuildTree();
}

// ─── DOM references ───────────────────────────────────────────────────────────
let guessCount = 0;

const input        = document.getElementById('species-input') as HTMLInputElement;
const datalist     = document.getElementById('species-list') as HTMLDataListElement;
const btn          = document.getElementById('guess-btn') as HTMLButtonElement;
const list         = document.getElementById('guess-list') as HTMLUListElement;
const guessesLabel = document.getElementById('guesses-left') as HTMLSpanElement;
const gameControls = document.getElementById('game-controls') as HTMLDivElement;
const successArea  = document.getElementById('success-area') as HTMLDivElement;

// Populate success target name
(document.getElementById('success-name') as HTMLElement).textContent = cap(TARGET.name);
(document.getElementById('success-scientific') as HTMLElement).textContent = TARGET.scientific;

// Autocomplete: sorted, shown only when letters are typed
const ALL_SPECIES = Object.keys(TAXONOMY).map(cap).sort();

function updateDatalist(query: string) {
  datalist.innerHTML = '';
  if (!query) return;
  const guessed = new Set([...missAtClade.values()].flat());
  const ql = query.toLowerCase();
  const matches = ALL_SPECIES.filter(n => !guessed.has(n.toLowerCase()) && n.toLowerCase().includes(ql));
  matches.sort((a, b) => {
    const al = a.toLowerCase(), bl = b.toLowerCase();
    const aStart = al.startsWith(ql), bStart = bl.startsWith(ql);
    if (aStart !== bStart) return aStart ? -1 : 1;
    return al.localeCompare(bl);
  });
  matches.forEach(n => {
    const opt = document.createElement('option');
    opt.value = n;
    datalist.appendChild(opt);
  });
}
input.addEventListener('input', () => {
  const val = input.value.trim();
  updateDatalist(val);
  // Auto-submit when an exact taxonomy match is selected (e.g. from datalist click)
  if (val && TAXONOMY[val.toLowerCase()]) {
    setTimeout(submitGuess, 50);
  }
});

// Restore if already done
if (localStorage.getItem('species_done')) {
  gameControls.style.display = 'none';
  showSuccess();
}

function showSuccess() {
  successArea.style.display = 'block';
}

function updateGuessesLabel() {
  guessesLabel.textContent = `(${guessCount})`;
}

function renderGuesses() {
  list.innerHTML = '';
  for (const [clade, names] of missAtClade) {
    for (const n of names) {
      const cls = CLADE_CLASS[clade] ?? 'hint-cold';
      const t = TAXONOMY[n];
      const li = document.createElement('li');
      li.className = 'guess-row';
      li.innerHTML = `<span class="guess-name">${cap(n)}</span><span class="hint-pill ${cls}">${t?.label ?? ''}</span>`;
      list.appendChild(li);
    }
  }
}

function submitGuess() {
  const raw = input.value.trim().toLowerCase();
  if (!raw) return;
  input.value = '';
  updateDatalist('');

  const data = TAXONOMY[raw];
  if (data && [...missAtClade.values()].some(list => list.includes(raw))) return;

  if (!data) {
    const li = document.createElement('li');
    li.className = 'guess-row';
    li.innerHTML = `<span class="guess-name">${raw}</span><span class="hint-pill hint-cold">Unknown species</span>`;
    list.prepend(li);
    return;
  }

  if (data.clade === CORRECT_CLADE) {
    localStorage.setItem('species_done', '1');
    localStorage.setItem('spirit_animal', TARGET.name);
    _won = true;
    rebuildTree();
    gameControls.style.display = 'none';
    showSuccess();
    return;
  }

  guessCount++;
  updateGuessesLabel();
  highlightNode(data.clade, raw);
  renderGuesses();
}

btn.addEventListener('click', submitGuess);
input.addEventListener('keydown', (e) => { if (e.key === 'Enter') submitGuess(); });
</script>
