---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Species Identification Tool" showTimer={true}>

  <div class="page-header">
    <div class="container">
      <div class="breadcrumb"><a href="/">Home</a> / <a href="/platform/">Platform</a> / Species Identification</div>
      <h1>Species Identification Tool</h1>
      <p>Identify the spirit animal of the Project Coordinator who owns your gnomics sample.</p>
    </div>
  </div>

  <section>
    <div class="container">
      <div class="species-game-layout">

        <!-- Left: game -->
        <div class="species-game">

          <div class="alert alert-info mb-2">
            <strong>Instructions:</strong> Every Project Coordinator has a spirit animal.
            Identify the spirit animal linked to your sample by entering species names below.
            Each guess returns a phylogenetic proximity hint.
            You have <strong>20 guesses</strong>.
          </div>

          <div id="game-area">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.5rem;">
              <span id="guesses-left" style="font-size:0.85rem;" class="text-muted">10 guesses remaining</span>
            </div>
            <datalist id="species-list"></datalist>
            <div class="species-input-row">
              <input type="text" id="species-input" placeholder="Enter a species name…" list="species-list" autocomplete="off" />
              <button class="btn btn-primary" id="guess-btn">Submit</button>
            </div>
            <ul class="guess-history" id="guess-list"></ul>
          </div>

          <div id="fail-area" style="display:none;" class="fail-box">
            <div style="font-size:3rem;">😔</div>
            <h3>Out of Guesses</h3>
            <p>The spirit animal was a <strong id="fail-name"></strong> (<em id="fail-scientific"></em>).</p>
            <button id="retry-btn" class="btn btn-outline mt-2">🔄 Try Again</button>
          </div>

          <div id="success-area" style="display:none;" class="success-box">
            <div style="font-size:3rem;">🎉</div>
            <h3>Spirit Animal Identified!</h3>
            <p>The Project Coordinator's spirit animal is a <strong id="success-name"></strong> (<em id="success-scientific"></em>).</p>
            <p class="text-muted" style="font-size:0.9rem;">
              Proceed to the physical puzzle in your team box.<br/>
              Once assembled, return here to continue.
            </p>
            <a href="/platform/submit/" class="btn btn-primary mt-2">Continue to Project Submission →</a>
          </div>

        </div>

        <!-- Right: phylogenomic tree -->
        <div class="phylo-panel">
          <h4 style="margin-bottom:1rem;font-size:0.85rem;text-transform:uppercase;letter-spacing:0.05em;opacity:0.7;">Phylogenomic Tree</h4>
          <div class="phylo-tree">
            <div class="phylo-node" id="node-metazoa">Metazoa</div>
            <div class="phylo-branch" id="branch-metazoa" style="display:none">
              <div class="phylo-subtree">
                <div class="phylo-node" id="node-bilateria">Bilateria</div>
                <div class="phylo-branch" id="branch-bilateria" style="display:none">
                  <div class="phylo-subtree">
                    <div class="phylo-node" id="node-deuterostomia">Deuterostomia</div>
                    <div class="phylo-branch" id="branch-deuterostomia" style="display:none">
                      <div class="phylo-subtree">
                        <div class="phylo-node" id="node-chordata">Chordata</div>
                        <div class="phylo-branch" id="branch-chordata" style="display:none">
                          <div class="phylo-subtree">
                            <div class="phylo-node" id="node-vertebrata">Vertebrata</div>
                            <div class="phylo-branch" id="branch-vertebrata" style="display:none">
                              <div class="phylo-subtree">
                                <div class="phylo-node" id="node-amniota">Amniota</div>
                                <div class="phylo-branch" id="branch-amniota" style="display:none">
                                  <div class="phylo-subtree">
                                    <div class="phylo-node" id="node-mammalia">Mammalia</div>
                                    <div class="phylo-branch" id="branch-mammalia" style="display:none">
                                      <div class="phylo-subtree">
                                        <div class="phylo-node" id="node-rodentia">Rodentia</div>
                                        <div class="phylo-branch" id="branch-rodentia" style="display:none">
                                          <div class="phylo-subtree">
                                            <div class="phylo-node" id="node-caviidae">Caviidae</div>
                                            <div class="phylo-branch" id="branch-caviidae" style="display:none">
                                              <div class="phylo-subtree">
                                                <div class="phylo-node phylo-target" id="node-target">???</div>
                                              </div>
                                            </div>
                                          </div>
                                          <div class="phylo-subtree">
                                            <div class="phylo-node" id="node-other-rodentia">Other Rodentia</div>
                                          </div>
                                        </div>
                                      </div>
                                      <div class="phylo-subtree">
                                        <div class="phylo-node" id="node-other-mammalia">Other Mammalia</div>
                                      </div>
                                    </div>
                                  </div>
                                  <div class="phylo-subtree">
                                    <div class="phylo-node" id="node-other-amniota">Other Amniota</div>
                                  </div>
                                </div>
                              </div>
                              <div class="phylo-subtree">
                                <div class="phylo-node" id="node-other-vertebrata">Other Vertebrata</div>
                              </div>
                            </div>
                          </div>
                          <div class="phylo-subtree">
                            <div class="phylo-node" id="node-other-chordata">Other Chordata</div>
                          </div>
                        </div>
                      </div>
                      <div class="phylo-subtree">
                        <div class="phylo-node" id="node-other-deuterostomia">Other Deuterostomia</div>
                      </div>
                    </div>
                  </div>
                  <div class="phylo-subtree">
                    <div class="phylo-node" id="node-protostomia">Protostomia</div>
                  </div>
                </div>
              </div>
              <div class="phylo-subtree">
                <div class="phylo-node" id="node-non-bilateria">Non-Bilateria</div>
              </div>
            </div>
          </div>
          <div id="clade-desc" class="clade-desc" style="display:none;"></div>
        </div>

      </div>
    </div>
  </section>

</Layout>

<script>
// ─── Target configuration (change here to update the spirit animal) ───────────
const TARGET = {
  name:       'capybara',
  scientific: 'Hydrochoerus hydrochaeris',
  emoji:      '🦫',
