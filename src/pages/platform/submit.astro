---
import Layout from '../../layouts/Layout.astro';

// Keyphrase → accession ID mapping (one per team)
// Keyphrases come from the paper overlay applied to the gnomics-pipeline commit file
const KEYPHRASES: Record<string, string> = {
  'MUSHROOM':  'GNI-2026-001',
  'TOADSTOOL': 'GNI-2026-002',
  'POINTED':   'GNI-2026-003',
  'GROTTO':    'GNI-2026-004',
  'REDCAP':    'GNI-2026-005',
};
---
<Layout title="Project Submission" showTimer={true}>

  <div class="page-header">
    <div class="container">
      <h1>Project Submission</h1>
      <p>Submit your gnomics project to retrieve your assigned accession ID.</p>
    </div>
  </div>

  <section>
    <div class="container">
      <div class="submit-form">

        <div class="alert alert-info mb-2">
          <strong>Step 4 of 6 — Project keyphrase.</strong><br/>
          Enter the project keyphrase you extracted from the pipeline repository using your team overlay.
        </div>

        <div id="form-area">
          <div class="form-group">
            <label for="keyphrase">Project Keyphrase</label>
            <input type="text" id="keyphrase" placeholder="Enter keyphrase (all caps)" autocomplete="off" style="font-family:var(--font-mono);font-size:1.1rem;letter-spacing:0.08em;" />
          </div>
          <button class="btn btn-primary" id="submit-btn" style="width:100%;padding:0.75rem;">
            Submit Keyphrase
          </button>
          <p class="text-muted mt-2" style="font-size:0.85rem;">
            The keyphrase was obtained in step 4 by overlaying your team's physical decoder sheet on the
            printed output from the <a href="https://github.com/NationalGnomicsInfrastructure/gnomics-pipeline" target="_blank">gnomics-pipeline</a> repository.
          </p>
        </div>

        <div id="error-msg" style="display:none;" class="alert alert-warning mt-2">
          ❌ Keyphrase not recognised. Check your decoder overlay and try again.
        </div>

        <div id="result-area" style="display:none;">
          <div class="alert alert-success">
            ✅ Keyphrase accepted! Your accession ID has been assigned.
          </div>
          <div class="accession-card">
            <div class="acc-id" id="acc-id-display">—</div>
            <p style="font-size:0.88rem;color:var(--text-muted);margin-bottom:0.75rem;">
              Look up this accession ID in the <a href="/database/">Gnomics Database</a> to retrieve your sample metadata.
            </p>
            <a href="/database/" class="btn btn-primary">Open Gnomics Database →</a>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>

<script>
const KEYPHRASES: Record<string, string> = {
  'MUSHROOM':  'GNI-2026-001',
  'TOADSTOOL': 'GNI-2026-002',
  'POINTED':   'GNI-2026-003',
  'GROTTO':    'GNI-2026-004',
  'REDCAP':    'GNI-2026-005',
};

const submitBtn  = document.getElementById('submit-btn') as HTMLButtonElement;
const formArea   = document.getElementById('form-area') as HTMLDivElement;
const resultArea = document.getElementById('result-area') as HTMLDivElement;
const errorMsg   = document.getElementById('error-msg') as HTMLDivElement;
const accDisplay = document.getElementById('acc-id-display') as HTMLDivElement;
const keyphraseInput = document.getElementById('keyphrase') as HTMLInputElement;

// Restore if already submitted
const savedAcc = localStorage.getItem('gnomics_accession');
if (savedAcc) {
  formArea.style.display = 'none';
  resultArea.style.display = 'block';
  accDisplay.textContent = savedAcc;
}

submitBtn.addEventListener('click', () => {
  const kp = keyphraseInput.value.trim().toUpperCase();
  const acc = KEYPHRASES[kp];
  if (!acc) {
    errorMsg.style.display = 'block';
    return;
  }
  errorMsg.style.display = 'none';
  localStorage.setItem('gnomics_accession', acc);
  formArea.style.display = 'none';
  resultArea.style.display = 'block';
  accDisplay.textContent = acc;
});

keyphraseInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') submitBtn.click(); });
</script>
