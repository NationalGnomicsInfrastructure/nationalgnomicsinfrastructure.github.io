  'prairie dog':      { clade: 3, label: '🌡️ Very warm — Rodentia' },
  'woodchuck':        { clade: 3, label: '🌡️ Very warm — Rodentia' },
  'degu':             { clade: 3, label: '🌡️ Very warm — Rodentia' },
  // Mammalia non-rodent (clade 2)
  'rabbit':           { clade: 2, label: '🌤️ Warm — Mammalia, not Rodentia' },
