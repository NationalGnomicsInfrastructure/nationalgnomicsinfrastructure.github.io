---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Project Detangling" showTimer={true}>

  <div class="page-header">
    <div class="container">
      <h1>Project Detangling</h1>
      <p>Uncover the next clue using the second animal from your envelope.</p>
    </div>
  </div>

  <section>
    <div class="container">
      <div class="submit-form">

        <div class="alert alert-info mb-2">
          <strong>Second animal.</strong><br/>
          Enter the second animal from your envelope to reveal the next clue.
        </div>

        <div id="form-area">
          <div class="form-group">
            <label for="second-animal">Second Animal</label>
            <input type="text" id="second-animal" placeholder="Enter the second animal" autocomplete="off" style="font-size:1.1rem;" />
          </div>
          <button class="btn btn-primary" id="submit-btn" style="width:100%;padding:0.75rem;">
            Uncover Clue
          </button>
        </div>

        <div id="error-msg" style="display:none;" class="alert alert-warning mt-2">
          That's not the right animal. Check your envelope and try again.
        </div>

        <div id="result-area" style="display:none;">
          <div class="alert alert-success">
            Clue uncovered. Your delivery continues.
          </div>
          <div class="card mt-3" style="padding:1.25rem;">
            <p style="font-style:italic;font-size:1.1rem;line-height:1.6;" id="clue-text"></p>
            <a href="/platform/" class="btn btn-primary mt-2">Back to Platform</a>
          </div>
        </div>

      </div>
    </div>
  </section>
</Layout>

<script>
const PAIRS = [
  'Y2FweWJhcmE=',
  'a29tb2RvIGRyYWdvbg==',
  'YXhvbG90bA==',
  'Y2ljYWRh',
  'a29hbGE=',
  'c3RhcmZpc2g=',
];
const PARTS = [
  'SEVBRA==',
  'TU9VVEg=',
  'VE9OR1VF',
  'TEVH',
  'QVJNIEJPVFRPTSBSSUdIVCBDT1JORVI=',
  'RlJPTlQgUEFX',
];

function b64dec(s: string): string {
  return atob(s);
}

const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
const formArea = document.getElementById('form-area') as HTMLDivElement;
const resultArea = document.getElementById('result-area') as HTMLDivElement;
const errorMsg = document.getElementById('error-msg') as HTMLDivElement;
const input = document.getElementById('second-animal') as HTMLInputElement;
const clueText = document.getElementById('clue-text') as HTMLParagraphElement;

const codeIdx = parseInt(localStorage.getItem('code_idx') ?? '');
if (isNaN(codeIdx) || codeIdx < 0 || codeIdx >= PAIRS.length) {
  window.location.href = '/platform/';
}

if (!localStorage.getItem('accession')) {
  window.location.href = '/platform/';
}

if (localStorage.getItem('detangled')) {
  formArea.style.display = 'none';
  resultArea.style.display = 'block';
  const part = b64dec(PARTS[codeIdx]);
  clueText.textContent = `Look on the ${part.toLowerCase()}. Find me in the pipeline.`;
}

submitBtn.addEventListener('click', () => {
  const answer = input.value.trim().toLowerCase();
  const correct = b64dec(PAIRS[codeIdx]);
  if (answer !== correct) {
    errorMsg.style.display = 'block';
    return;
  }
  errorMsg.style.display = 'none';
  localStorage.setItem('detangled', '1');
  formArea.style.display = 'none';
  resultArea.style.display = 'block';
  const part = b64dec(PARTS[codeIdx]);
  clueText.textContent = `Look on the ${part.toLowerCase()}. Find me in the pipeline.`;
});

input.addEventListener('keydown', (e) => {
  if (e.key === 'Enter') submitBtn.click();
});
</script>
