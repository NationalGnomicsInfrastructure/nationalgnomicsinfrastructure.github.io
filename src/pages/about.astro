---
import Layout from '../layouts/Layout.astro';
---
<Layout title="About">
  <div class="page-header">
    <div class="container">
      <h1>About NGnI</h1>
      <p>The National Gnomics Infrastructure — part of SciLifeLab.</p>
    </div>
  </div>
  <section>
    <div class="container" style="max-width:720px;">
      <h2>Our Mission</h2>
      <p>
        The National Gnomics Infrastructure (NGnI) provides state-of-the-art gnomics technologies and bioinformatics
        expertise to researchers across Sweden. We are hosted at SciLifeLab and serve as a national resource for
        gnome-scale sequencing, spatial gnomics, and ancient gnomics.
      </p>
      <h2 class="mt-3">Our Teams</h2>
      <div class="cards mt-2">
        <div class="card">
          <div class="card-icon">🧬</div>
          <h3>Gnome Sequencing</h3>
          <p>High-throughput short- and long-read sequencing for whole-gnome, targeted, and metagnomics projects.</p>
        </div>
        <div class="card">
          <div class="card-icon">🗺️</div>
          <h3>Spatial Gnomics</h3>
          <p>Spatial resolution of gnome transcriptomes using Visium, Xenium and proprietary NGnI technologies.</p>
        </div>
        <div class="card">
          <div class="card-icon">🏺</div>
          <h3>Ancient Gnomics</h3>
          <p>Recovery and analysis of degraded gnome DNA from archaeological and palaeontological specimens.</p>
        </div>
      </div>
      <h2 class="mt-4">Contact</h2>
      <p>For project enquiries, contact us at <a href="mailto:support@ngni.se">support@ngni.se</a>.</p>
    </div>
  </section>
</Layout>
