---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Technologies">
  <div class="page-header">
    <div class="container">
      <h1>Technologies</h1>
      <p>The instruments and platforms available at NGnI.</p>
    </div>
  </div>
  <section>
    <div class="container">
      <div class="cards">
        <div class="card">
          <div class="card-icon">🔬</div>
          <h3>GnomePore P2</h3>
          <p>Ultra-long read gnome sequencing with direct methylation detection.</p>
        </div>
        <div class="card">
          <div class="card-icon">⚡</div>
          <h3>GnomeSeq X Plus</h3>
          <p>High-throughput short-read sequencing with dual flow cell technology.</p>
        </div>
        <div class="card">
          <div class="card-icon">🧊</div>
          <h3>CryoGnome</h3>
          <p>Cryo-preserved library preparation for ancient and degraded gnome specimens.</p>
        </div>
        <div class="card">
          <div class="card-icon">🗺️</div>
          <h3>SpatialGnome HD</h3>
          <p>High-definition spatial gnome transcriptomics at sub-micron resolution.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
