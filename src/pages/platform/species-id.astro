  'pig':              { clade: 2, label: '🌤️ Warm — Mammalia' },
  'cow':              { clade: 2, label: '🌤️ Warm — Mammalia' },
  'horse':            { clade: 2, label: '🌤️ Warm — Mammalia' },
  'donkey':           { clade: 2, label: '🌤️ Warm — Mammalia' },
  'sheep':            { clade: 2, label: '🌤️ Warm — Mammalia' },
  'goat':             { clade: 2, label: '🌤️ Warm — Mammalia' },
  'dog':              { clade: 2, label: '🌤️ Warm — Mammalia' },
  'cat':              { clade: 2, label: '🌤️ Warm — Mammalia' },
  'bear':             { clade: 2, label: '🌤️ Warm — Mammalia' },
  'wolf':             { clade: 2, label: '🌤️ Warm — Mammalia' },
  'fox':              { clade: 2, label: '🌤️ Warm — Mammalia' },
  'deer':             { clade: 2, label: '🌤️ Warm — Mammalia' },
  'moose':            { clade: 2, label: '🌤️ Warm — Mammalia' },
  'elephant':         { clade: 2, label: '🌤️ Warm — Mammalia' },
  'giraffe':          { clade: 2, label: '🌤️ Warm — Mammalia' },
  'hippopotamus':     { clade: 2, label: '🌤️ Warm — Mammalia' },
  'rhinoceros':       { clade: 2, label: '🌤️ Warm — Mammalia' },
