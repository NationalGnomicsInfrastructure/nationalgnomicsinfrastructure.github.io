---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Gnomics Database" showTimer={true}>

  <div class="page-header">
    <div class="container">
      <h1>Gnomics Database</h1>
      <p>Query sample metadata and accession records from the NGnI data archive.</p>
    </div>
  </div>

  <section>
    <div class="container" style="max-width:760px;margin:0 auto;">

      <div id="record" style="display:none;margin-bottom:2rem;margin-top:-2.5rem;">
        <div class="accession-card">
          <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:1rem;">
            <h3 id="rec-title" style="margin:0;">—</h3>
            <div class="acc-id" id="rec-id">—</div>
          </div>
          <table>
            <tr><td><i class="fa-solid fa-map-location-dot"></i> Collection site</td><td id="rec-site">—</td></tr>
            <tr><td><i class="fa-solid fa-folder"></i> Category</td><td id="rec-category">—</td></tr>
            <tr><td><i class="fa-solid fa-tags"></i> Keywords</td><td id="rec-keywords">—</td></tr>
          </table>
          <p id="rec-desc" style="margin-top:1rem;font-size:0.92rem;color:var(--text-muted);"></p>
        </div>
      </div>

      <div class="form-group">
        <label for="acc-input">Search by Accession ID</label>
        <div style="display:flex;gap:0.75rem;">
          <input type="text" id="acc-input" placeholder="e.g. GNI-P000002"
            style="font-family:var(--font-mono);font-size:1rem;letter-spacing:0.05em;" />
          <button class="btn btn-primary" id="search-btn">Search</button>
        </div>
      </div>

      <div class="form-group" id="category-filters">
        <label>Filter by Category</label>
        <div style="display:flex;flex-wrap:wrap;gap:0.5rem;">
          <button class="btn btn-sm btn-filter active" data-cat="all">All</button>
          <button class="btn btn-sm btn-filter" data-cat="Food">Food</button>
          <button class="btn btn-sm btn-filter" data-cat="Office Supplies">Office Supplies</button>
          <button class="btn btn-sm btn-filter" data-cat="Electronics">Electronics</button>
          <button class="btn btn-sm btn-filter" data-cat="Home &amp; Decor">Home &amp; Decor</button>
          <button class="btn btn-sm btn-filter" data-cat="Accessories">Accessories</button>
          <button class="btn btn-sm btn-filter" data-cat="Plants">Plants</button>
          <button class="btn btn-sm btn-filter" data-cat="Furniture">Furniture</button>
        </div>
        <div id="category-results" style="margin-top:0.75rem;font-size:0.9rem;color:var(--text-muted);"></div>
      </div>

      <div id="not-found" style="display:none;" class="alert alert-warning">
        ❌ Accession ID not found. Please check the ID and try again.
      </div>

    </div>
  </section>

</Layout>

<script>
import DB_RAW from '../../data/gnomics-db.csv?raw';

function parseCSVLine(line: string): string[] {
  const result: string[] = [];
  let cur = '';
  let q = false;
  for (let i = 0; i < line.length; i++) {
    const c = line[i];
    if (q) {
      if (c === '"') {
        if (i + 1 < line.length && line[i + 1] === '"') { cur += '"'; i++; }
        else { q = false; }
      } else { cur += c; }
    } else {
      if (c === '"') { q = true; }
      else if (c === ',') { result.push(cur); cur = ''; }
      else { cur += c; }
    }
  }
  result.push(cur);
  return result;
}

const DB: Record<string, { title: string; site: string; keywords: string[]; description: string; category: string; }> = {};

for (const line of DB_RAW.trim().split('\n').slice(1)) {
  const v = parseCSVLine(line);
  DB[v[0]] = {
    title: v[1], site: v[2], category: v[3],
    keywords: v[4].split('|').filter(Boolean),
    description: v[5],
  };
}

const accInput  = document.getElementById('acc-input') as HTMLInputElement;
const searchBtn = document.getElementById('search-btn') as HTMLButtonElement;
const notFound  = document.getElementById('not-found') as HTMLDivElement;
const record    = document.getElementById('record') as HTMLDivElement;
const resultsEl = document.getElementById('category-results') as HTMLDivElement;

function search() {
  const q = accInput.value.trim().toLowerCase();
  notFound.style.display = 'none';
  record.style.display = 'none';

  // Exact ID match → show full record
  const exact = DB[q.toUpperCase()];
  if (exact) {
    const id = q.toUpperCase();
    (document.getElementById('rec-id') as HTMLElement).innerHTML = `<a href="#${id}" data-id="${id}" style="color:var(--accent);text-decoration:none;cursor:pointer;">${id}</a>`;
    (document.getElementById('rec-title') as HTMLElement).textContent = exact.title;
    (document.getElementById('rec-site') as HTMLElement).textContent = exact.site;
    (document.getElementById('rec-category') as HTMLElement).textContent = exact.category;
    (document.getElementById('rec-keywords') as HTMLElement).textContent = exact.keywords.join(', ');
    (document.getElementById('rec-desc') as HTMLElement).textContent = exact.description;
    record.style.display = 'block';
    return;
  }

  // No query → clear results
  if (!q) { resultsEl.innerHTML = ''; return; }

  // Full-text search across title, category, site, description, keywords
  const matches = Object.keys(DB).filter(id => {
    const e = DB[id];
    return e.title.toLowerCase().includes(q) ||
           e.category.toLowerCase().includes(q) ||
           e.site.toLowerCase().includes(q) ||
           e.description.toLowerCase().includes(q) ||
           e.keywords.some(k => k.toLowerCase().includes(q));
  });
  if (matches.length === 0) { notFound.style.display = 'block'; return; }
const list = matches.map(id => `<a href="#${id}" data-id="${id}" style="color:var(--accent);text-decoration:none;font-size:0.85rem;cursor:pointer;"><code style="font-size:0.85rem;">${id}</code></a>`).join(' ');
  resultsEl.innerHTML = `<strong>${matches.length}</strong> result${matches.length === 1 ? '' : 's'} — ${list}`;
}

searchBtn.addEventListener('click', search);
accInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') search(); });

// Hash-based navigation
function searchHash() {
  const hash = location.hash.replace('#', '').trim().toUpperCase();
  if (hash && DB[hash]) { accInput.value = hash; search(); }
}
window.addEventListener('hashchange', searchHash);
if (location.hash) searchHash();



// Category filter
const filterCats = document.querySelectorAll('.btn-filter') as NodeListOf<HTMLButtonElement>;
let activeCat = 'all';

function showResults() {
  const ids = Object.keys(DB).filter(id => activeCat === 'all' || DB[id].category === activeCat);
  if (ids.length === 0) {
    resultsEl.textContent = 'No entries in this category.';
    return;
  }
  const list = ids.map(id => `<a href="#${id}" data-id="${id}" style="color:var(--accent);text-decoration:none;font-size:0.85rem;cursor:pointer;"><code style="font-size:0.85rem;">${id}</code></a>`).join(' ');
  resultsEl.innerHTML = `<strong>${ids.length}</strong> result${ids.length === 1 ? '' : 's'} — ${list}`;
}

filterCats.forEach(btn => {
  btn.addEventListener('click', () => {
    filterCats.forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    activeCat = btn.dataset.cat!;
    showResults();
  });
});

// Delegated click on result links
document.addEventListener('click', (e) => {
  const link = (e.target as HTMLElement).closest('a[data-id]');
  if (!link) return;
  e.preventDefault();
  const id = link.getAttribute('data-id')!;
  (document.getElementById('acc-input') as HTMLInputElement).value = id;
  window.location.hash = id;
  search();
  document.querySelector('.page-header')!.scrollIntoView({ behavior: 'smooth', block: 'start' });
});

</script>
