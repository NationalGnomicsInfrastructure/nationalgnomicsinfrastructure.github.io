  'tunicate':         { clade: 3, label: '❄️ Cold — Chordata, not Vertebrata' },
  'sea squirt':       { clade: 3, label: '❄️ Cold — Chordata, not Vertebrata' },
  // Deuterostomia non-Chordata: echinoderms (clade 2)
