---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  showTimer?: boolean;
}
const { title, description = "National Gnomics Infrastructure — Advancing gnome-scale genomic discovery", showTimer = false } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | NGnI</title>
  <meta name="description" content={description} />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🧙</text></svg>" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>
<body>

<div class="redirect-banner">
  🧬 Looking for the <strong>real</strong> National Genomics Infrastructure?
  Visit <a href="https://ngisweden.scilifelab.se/" target="_blank" rel="noopener">ngisweden.scilifelab.se</a>
</div>

<header class="site-header" id="site-header">
  <div class="header-inner">
    <a href="/" class="site-logo">
      <img src="/ngni-logo.png" alt="NGnI" style="height:2.8rem;vertical-align:middle;" />
      <span>National Gnomics Infrastructure</span>
    </a>
    <button class="burger" id="burger" aria-label="Toggle navigation" aria-expanded="false">
      <span class="burger-bar"></span>
      <span class="burger-bar"></span>
      <span class="burger-bar"></span>
    </button>
    <nav id="nav">
      <a href="/applications/">Applications</a>
      <a href="/technologies/">Technologies</a>
      <a href="/database/">Database</a>
      <a href="/platform/">Platform</a>
      <a href="/about/">About</a>
    </nav>
  </div>
</header>

<script>
  document.getElementById('burger')?.addEventListener('click', function () {
    document.getElementById('site-header')?.classList.toggle('nav-open');
    const expanded = this.getAttribute('aria-expanded') === 'true' ? 'false' : 'true';
    this.setAttribute('aria-expanded', expanded);
  });
</script>

{showTimer && (
  <div id="timer-bar">
    <div class="timer-label">Delivery time remaining</div>
    <div class="timer-time" id="timer-display">--:--</div>
    <div id="timer-btns" style="display:none;margin-top:0.5rem;display:none;gap:0.35rem;flex-direction:row;">
      <button id="restart-btn" onclick="if(confirm('⏮️ This will reset the timer and progress, but keep you connected. Are you sure?')){['start','species_done','spirit_animal','accession','detangled','identification_done','delivery_done'].forEach(k=>localStorage.removeItem(k));window.location.href='/platform/'}" style="flex:1;font-size:0.75rem;padding:0.2rem 0.5rem;background:transparent;border:1px solid rgba(255,255,255,0.5);color:inherit;border-radius:4px;cursor:pointer;"><i class="fa-solid fa-backward-step"></i> Restart</button>
      <button id="stop-btn" onclick="if(confirm('⏹️ This will fully end the delivery and clear all data. Are you sure?')){['start','team','leader','species_done','spirit_animal','accession','code_idx','mode','detangled','identification_done','delivery_done'].forEach(k=>localStorage.removeItem(k));window.location.href='/platform/'}" style="flex:1;font-size:0.75rem;padding:0.2rem 0.5rem;background:transparent;border:1px solid rgba(255,100,100,0.5);color:inherit;border-radius:4px;cursor:pointer;"><i class="fa-solid fa-stop"></i> Stop</button>
    </div>
  </div>
)}

<slot />

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-col" style="text-align:center;">
        <h4>NGnI</h4>
        <div style="display:flex;align-items:center;justify-content:center;gap:0.75rem;margin-top:0.75rem;">
          <a href="https://github.com/NationalGnomicsInfrastructure" target="_blank" rel="noopener">
            <img src="/ngni-logo.png" alt="NGnI" style="height:3.5rem;opacity:0.85;" />
          </a>
          <a href="https://github.com/SciFiLab" target="_blank" rel="noopener">
            <img src="/scifilab-symbol.svg" alt="SciFiLab" style="height:3.5rem;opacity:0.85;" />
          </a>
        </div>
        <p style="font-size:0.85rem;line-height:1.5;margin-top:0.75rem;">Part of the Gnomics Platform at SciFiLab.</p>
      </div>
      <div class="footer-col" style="max-width:300px;">
        <h4>Applications</h4>
        <ul style="display:grid;grid-template-columns:1fr 1fr;gap:0.15rem 0.75rem;">
          <li><a href="/applications/gnome-sequencing/">Gnome Sequencing</a></li>
          <li><a href="/applications/spatial-gnomics/">Spatial Gnomics</a></li>
          <li><a href="/applications/ancient-gnomics/">Ancient Gnomics</a></li>
          <li><a href="/applications/mycognomics/">Mycognomics</a></li>
          <li><a href="/applications/epignomics/">Epignomics</a></li>
          <li><a href="/applications/pharmagnomics/">Pharmagnomics</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Resources</h4>
        <ul>
          <li><a href="/platform/">Platform</a></li>
          <li><a href="/database/">Database</a></li>
          <li><a href="https://github.com/NationalGnomicsInfrastructure/crepes">Pipeline Code</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>About</h4>
        <ul>
          <li><a href="/about/">About</a></li>
          <li><a href="/about/#contact">Contact form</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2026 National Gnomics Infrastructure, SciFiLab</span>
      <span>Gnomenhavn, Listenbourg</span>
    </div>
  </div>
</footer>

{showTimer && (
  <script>
    (function () {
      const DURATION_MS = 45 * 60 * 1000; // 45 minutes

      function startTimer() {
        const bar = document.getElementById('timer-bar');
        const display = document.getElementById('timer-display');
        if (!bar || !display) return;

        if (localStorage.getItem('delivery_done')) {
          const label = document.querySelector('.timer-label');
          if (label) label.textContent = 'Delivery completed';
          display.textContent = '✅ Project Delivered';
          return;
        }

        let startAt = parseInt(localStorage.getItem('start') || '0', 10);
        if (!startAt) return;

        bar.classList.add('running');
        const timerBtns = document.getElementById('timer-btns');
        if (timerBtns) timerBtns.style.display = 'flex';

        function tick() {
          const elapsed = Date.now() - startAt;
          const remaining = Math.max(0, DURATION_MS - elapsed);
          const min = Math.floor(remaining / 60000);
          const sec = Math.floor((remaining % 60000) / 1000);
          if (display) display.textContent = `${String(min).padStart(2,'0')}:${String(sec).padStart(2,'0')}`;
          if (bar) bar.classList.toggle('warning', remaining < 10 * 60 * 1000 && remaining >= 5 * 60 * 1000);
          if (bar) bar.classList.toggle('danger', remaining < 5 * 60 * 1000);
          // Interpolate border from lime (#a3e635) → red (#ff6b6b) as time runs out
          if (bar) {
            const progress = 1 - remaining / DURATION_MS; // 0 → 1
            const r = Math.round(163 + (255 - 163) * progress);
            const g = Math.round(230 + (107 - 230) * progress);
            const b = Math.round(53  + (107 - 53)  * progress);
            bar.style.borderColor = `rgb(${r},${g},${b})`;
          }
          if (remaining > 0) requestAnimationFrame(tick);
          else if (display) display.textContent = '00:00';
        }
        tick();
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', startTimer);
      } else {
        startTimer();
      }
      window.addEventListener('started', startTimer);
    })();
  </script>
)}

</body>
</html>
