      '🌤️ <strong>Pterygota — non-Hemiptera</strong> — Winged insects, wrong order. Beetles, bees, butterflies.',
      '🌡️ <strong>Hemiptera — non-Cicadidae</strong> — True bugs! Aphids, stink bugs, leafhoppers.',
      '🔥 <strong>Cicadidae</strong> — The cicada family. Extremely close!',
    ],
  },
];

// ─── Select or restore target ─────────────────────────────────────────────────
let targetIdx = parseInt(localStorage.getItem('gnomics_target') ?? '');
if (isNaN(targetIdx) || targetIdx < 0 || targetIdx >= POSSIBLE_TARGETS.length) {
  targetIdx = Math.floor(Math.random() * POSSIBLE_TARGETS.length);
  localStorage.setItem('gnomics_target', String(targetIdx));
}
const TARGET = POSSIBLE_TARGETS[targetIdx];
const CORRECT_CLADE = TARGET.path.length + 1; // 9

// ─── Compute taxonomy dynamically ─────────────────────────────────────────────
// For each species, find the deepest path node it shares with the target (in order).
const WARMTH_ICON = ['🥶','🧊','🧊','❄️','❄️','🌤️','🌤️','🌡️','🔥'];
const WARMTH_WORD = ['Very cold','Cold','Cold','Cool','Cool','Warm','Warm','Hot','Very hot'];

const TAXONOMY: Record<string, { clade: number; label: string }> = {};
for (const [species, data] of Object.entries(SPECIES_DB)) {
  if (species === TARGET.name) {
    TAXONOMY[species] = { clade: CORRECT_CLADE, label: '✅ Correct!' };
    continue;
  }
  let clade = 0;
  for (let i = 0; i < TARGET.path.length; i++) {
    if (data.path.includes(TARGET.path[i])) {
      clade = i + 1;
    } else {
      break;
    }
  }
  const pathLabel = clade > 0 ? TARGET.labels[clade - 1] : 'Non-Bilateria';
  const icon = WARMTH_ICON[clade] ?? '🧊';
  const word = WARMTH_WORD[clade] ?? 'Cold';
  TAXONOMY[species] = { clade, label: `${icon} ${word} — ${pathLabel} (${data.display})` };
}

// ─── Derive node/branch IDs from the chosen target's path ─────────────────────
const CLADE_NODE: Record<number, string>   = { 0: 'node-metazoa' };
const CLADE_BRANCH: Record<number, string> = { 0: 'branch-metazoa' };
TARGET.path.forEach((id, i) => {
  CLADE_NODE[i + 1]   = `node-${id}`;
  CLADE_BRANCH[i + 1] = `branch-${id}`;
});

const CLADE_CLASS: Record<number, string> = {
  0: 'hint-cold', 1: 'hint-cold', 2: 'hint-cold', 3: 'hint-cold',
  4: 'hint-cold', 5: 'hint-warm', 6: 'hint-warm', 7: 'hint-hot', 8: 'hint-hot',
};

// ─── Build phylogenomic tree HTML dynamically ─────────────────────────────────
function buildTree(): void {
  // Recursively builds the content to place inside the branch at depth-1.
  // Returns two sibling subtrees: [correct path node + its branch, other branch label].
  function buildFromDepth(depth: number): string {
    if (depth >= TARGET.path.length) {
      return `<div class="phylo-subtree"><div class="phylo-node phylo-target" id="node-target">???</div></div>`;
    }
    const id    = TARGET.path[depth];
    const label = TARGET.labels[depth];
    const other = TARGET.others[depth];
    return `
      <div class="phylo-subtree">
        <div class="phylo-node" id="node-${id}">${label}</div>
        <div class="phylo-branch" id="branch-${id}" style="display:none">
          ${buildFromDepth(depth + 1)}
        </div>
      </div>
      <div class="phylo-subtree"><div class="phylo-node">${other}</div></div>`;
  }

  const container = document.getElementById('phylo-tree')!;
  container.innerHTML = `
    <div class="phylo-node" id="node-metazoa">Metazoa</div>
    <div class="phylo-branch" id="branch-metazoa" style="display:none">
      ${buildFromDepth(0)}
    </div>`;
}
buildTree();

// ─── DOM references ───────────────────────────────────────────────────────────
const MAX_GUESSES = 20;
let guessesLeft = MAX_GUESSES;

const input        = document.getElementById('species-input') as HTMLInputElement;
const datalist     = document.getElementById('species-list') as HTMLDataListElement;
const btn          = document.getElementById('guess-btn') as HTMLButtonElement;
const list         = document.getElementById('guess-list') as HTMLUListElement;
const guessesLabel = document.getElementById('guesses-left') as HTMLSpanElement;
const gameArea     = document.getElementById('game-area') as HTMLDivElement;
const successArea  = document.getElementById('success-area') as HTMLDivElement;
const failArea     = document.getElementById('fail-area') as HTMLDivElement;
const cladeDesc    = document.getElementById('clade-desc') as HTMLDivElement;
const retryBtn     = document.getElementById('retry-btn') as HTMLButtonElement;

// Populate success/fail target name
const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
(document.getElementById('success-name') as HTMLElement).textContent = cap(TARGET.name);
(document.getElementById('success-scientific') as HTMLElement).textContent = TARGET.scientific;
(document.getElementById('fail-name') as HTMLElement).textContent = cap(TARGET.name);
(document.getElementById('fail-scientific') as HTMLElement).textContent = TARGET.scientific;

// Autocomplete: sorted, shown only when letters are typed
const ALL_SPECIES = Object.keys(TAXONOMY).map(cap).sort();

function updateDatalist(query: string) {
  datalist.innerHTML = '';
  if (!query) return;
  const q = query.toLowerCase();
  ALL_SPECIES.filter(n => n.toLowerCase().startsWith(q)).forEach(n => {
    const opt = document.createElement('option');
    opt.value = n;
    datalist.appendChild(opt);
  });
}
input.addEventListener('input', () => {
  const val = input.value.trim();
  updateDatalist(val);
  // Auto-submit when an exact taxonomy match is selected (e.g. from datalist click)
  if (val && TAXONOMY[val.toLowerCase()]) {
    setTimeout(submitGuess, 50);
  }
});

// Restore if already done
if (localStorage.getItem('gnomics_species_done')) {
  gameArea.style.display = 'none';
  successArea.style.display = 'block';
}

function highlightNode(clade: number) {
  for (let c = 0; c <= clade && c <= TARGET.path.length; c++) {
    document.getElementById(CLADE_NODE[c])?.classList.add('phylo-node-hit');
    const el = document.getElementById(CLADE_BRANCH[c]);
    if (el) el.style.display = '';
  }
}

function updateGuessesLabel() {
  guessesLabel.textContent = `${guessesLeft} guess${guessesLeft === 1 ? '' : 'es'} remaining`;
  guessesLabel.style.color = guessesLeft <= 3 ? '#c0392b' : '';
}
updateGuessesLabel();

function submitGuess() {
  const raw = input.value.trim().toLowerCase();
  if (!raw) return;
  input.value = '';
  updateDatalist('');

  const data = TAXONOMY[raw];
  const li = document.createElement('li');
  li.className = 'guess-row';

  if (!data) {
    li.innerHTML = `<span class="guess-name">${raw}</span><span class="hint-pill hint-cold">Unknown species</span>`;
    list.prepend(li);
    return;
  }

  if (data.clade === CORRECT_CLADE) {
    localStorage.setItem('gnomics_species_done', '1');
    const targetNode = document.getElementById('node-target')!;
    targetNode.textContent = cap(TARGET.name);
    targetNode.classList.add('phylo-node-hit', 'phylo-node-correct');
    for (let c = 0; c <= TARGET.path.length; c++) {
      document.getElementById(CLADE_NODE[c])?.classList.add('phylo-node-hit');
      const el = document.getElementById(CLADE_BRANCH[c]);
      if (el) el.style.display = '';
    }
    gameArea.style.display = 'none';
    successArea.style.display = 'block';
    return;
  }

  guessesLeft--;
  updateGuessesLabel();
  highlightNode(data.clade);

  const desc = TARGET.descs[data.clade];
  if (desc) { cladeDesc.innerHTML = desc; cladeDesc.style.display = 'block'; }

  const cls = CLADE_CLASS[data.clade] ?? 'hint-cold';
  li.innerHTML = `<span class="guess-name">${raw}</span><span class="hint-pill ${cls}">${data.label}</span>`;
  list.prepend(li);

  if (guessesLeft === 0) {
    gameArea.style.display = 'none';
    failArea.style.display = 'block';
  }
}

retryBtn?.addEventListener('click', () => {
  localStorage.removeItem('gnomics_target');
  window.location.reload();
});

btn.addEventListener('click', submitGuess);
input.addEventListener('keydown', (e) => { if (e.key === 'Enter') submitGuess(); });
</script>
