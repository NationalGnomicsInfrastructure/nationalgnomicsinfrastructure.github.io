  'monkey':           { clade: 2, label: '🌤️ Warm — Mammalia' },
  'gorilla':          { clade: 2, label: '🌤️ Warm — Mammalia' },
  'chimpanzee':       { clade: 2, label: '🌤️ Warm — Mammalia' },
  'human':            { clade: 2, label: '🌤️ Warm — Mammalia' },
  'whale':            { clade: 2, label: '🌤️ Warm — Mammalia' },
  'dolphin':          { clade: 2, label: '🌤️ Warm — Mammalia' },
  'seal':             { clade: 2, label: '🌤️ Warm — Mammalia' },
