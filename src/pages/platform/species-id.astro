  // Vertebrata non-mammal (clade 1)
  'crocodile':        { clade: 1, label: '❄️ Cold — Vertebrata, not Mammalia' },
  'alligator':        { clade: 1, label: '❄️ Cold — Vertebrata (reptile)' },
