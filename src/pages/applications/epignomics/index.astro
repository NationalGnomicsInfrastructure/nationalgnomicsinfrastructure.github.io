---
import Layout from "../../../layouts/Layout.astro";
---

<Layout title="Epignomics">
    <div class="page-header">
        <div class="container">
            <div class="breadcrumb">
                <a href="/">Home</a> / <a href="/applications/">Applications</a> /
                Epignomics
            </div>
            <h1>Epignomics</h1>
            <p>
                Methylation profiling and chromatin accessibility assays for
                gnome epigenome characterisation.
            </p>
        </div>
    </div>
    <section>
        <div class="container" style="max-width:760px;">
            <div class="cards mb-2">
                <div class="card">
                    <div class="card-icon">🌱</div><h3>MethylGnome</h3><p>
                        Whole-gnome bisulfite sequencing for comprehensive
                        methylation profiling at single-base resolution.
                    </p>
                </div>
                <div class="card">
                    <div class="card-icon">🧲</div><h3>MagnoGnome ChIP</h3><p>
                        Magnetic bead-based chromatin immunoprecipitation
                        sequencing for transcription factor binding sites.
                    </p>
                </div>
                <div class="card">
                    <div class="card-icon">🔓</div><h3>ATAC-Gnome</h3><p>
                        Assay for transposase-accessible chromatin across the
                        gnome epigenome at single-cell resolution.
                    </p>
                </div>
                <div class="card">
                    <div class="card-icon">📜</div><h3>Histone Gnomics</h3><p>
                        Genome-wide mapping of histone modification marks and
                        chromatin state dynamics in gnome tissues.
                    </p>
                </div>
            </div>
        </div>
    </section>
</Layout>
