const CLADE_DESC: Record<number, string> = {
  0: '🥶 <strong>Non-Bilateria</strong> — The earliest-branching animals: sponges, jellyfish, corals. No bilateral symmetry.',
  1: '🧊 <strong>Protostomia</strong> — Bilaterian animals where the mouth develops first. Includes molluscs, arthropods, and annelid worms.',
  2: '🧊 <strong>Deuterostomia (non-Chordata)</strong> — Bilaterian animals where the anus develops first. Echinoderms: starfish, sea urchins, sea cucumbers.',
  3: '❄️ <strong>Chordata (non-Vertebrata)</strong> — Animals with a notochord. Includes lancelets and tunicates but no backbone yet.',
  4: '🧊 <strong>Vertebrata (non-Amniota)</strong> — Animals with a backbone. Jawless fish, cartilaginous fish, bony fish, and amphibians.',
  5: '❄️ <strong>Amniota (non-Mammalia)</strong> — Vertebrates with an amniotic egg. Reptiles and birds.',
  6: '🌤️ <strong>Mammalia</strong> — Warm-blooded amniotes that nurse young with milk. ~6,400 living species.',
  7: '🌡️ <strong>Rodentia</strong> — The largest order of mammals (~2,500 species). Characterised by continuously growing incisors.',
  8: '🔥 <strong>Caviidae</strong> — South American rodents including guinea pigs, maras, and their relatives. ~14 species.',
};

const CLADE_NODE: Record<number, string> = {
  0: 'node-metazoa',
  1: 'node-bilateria',
  2: 'node-deuterostomia',
  3: 'node-chordata',
  4: 'node-vertebrata',
  5: 'node-amniota',
  6: 'node-mammalia',
  7: 'node-rodentia',
  8: 'node-caviidae',
};

const CLADE_BRANCH: Record<number, string> = {
  0: 'branch-metazoa',
  1: 'branch-bilateria',
  2: 'branch-deuterostomia',
  3: 'branch-chordata',
  4: 'branch-vertebrata',
  5: 'branch-amniota',
  6: 'branch-mammalia',
  7: 'branch-rodentia',
  8: 'branch-caviidae',
};

const CLADE_CLASS: Record<number, string> = {
  0: 'hint-cold',
  1: 'hint-cold',
  2: 'hint-cold',
  3: 'hint-cold',
  4: 'hint-cold',
  5: 'hint-warm',
  6: 'hint-warm',
  7: 'hint-hot',
  8: 'hint-hot',
};

const MAX_GUESSES = 20;
let guessesLeft = MAX_GUESSES;

const input        = document.getElementById('species-input') as HTMLInputElement;
const datalist     = document.getElementById('species-list') as HTMLDataListElement;
const btn          = document.getElementById('guess-btn') as HTMLButtonElement;
const list         = document.getElementById('guess-list') as HTMLUListElement;
const guessesLabel = document.getElementById('guesses-left') as HTMLSpanElement;
const gameArea     = document.getElementById('game-area') as HTMLDivElement;
const successArea  = document.getElementById('success-area') as HTMLDivElement;
const failArea     = document.getElementById('fail-area') as HTMLDivElement;
const cladeDesc    = document.getElementById('clade-desc') as HTMLDivElement;
const retryBtn     = document.getElementById('retry-btn') as HTMLButtonElement;

// Populate success/fail text from TARGET
(document.getElementById('success-name') as HTMLElement).textContent = TARGET.name;
(document.getElementById('success-scientific') as HTMLElement).textContent = TARGET.scientific;
(document.getElementById('fail-name') as HTMLElement).textContent = TARGET.name;
(document.getElementById('fail-scientific') as HTMLElement).textContent = TARGET.scientific;

// Autocomplete: sorted list, shown only when letters are typed
const ALL_SPECIES = Object.keys(TAXONOMY)
  .map(n => n.charAt(0).toUpperCase() + n.slice(1))
  .sort();

function updateDatalist(query: string) {
  datalist.innerHTML = '';
  if (!query) return;
  const q = query.toLowerCase();
  ALL_SPECIES
    .filter(n => n.toLowerCase().startsWith(q))
    .forEach(n => {
      const opt = document.createElement('option');
      opt.value = n;
      datalist.appendChild(opt);
    });
}

input.addEventListener('input', () => updateDatalist(input.value.trim()));

// Restore if already done
if (localStorage.getItem('gnomics_species_done')) {
  gameArea.style.display = 'none';
  successArea.style.display = 'block';
}

function highlightNode(clade: number) {
  // Light up all nodes up to this clade level and reveal their branches
  for (let c = 0; c <= clade && c <= 8; c++) {
    const nodeId = CLADE_NODE[c];
    if (nodeId) document.getElementById(nodeId)?.classList.add('phylo-node-hit');
    const branchId = CLADE_BRANCH[c];
    if (branchId) {
      const el = document.getElementById(branchId);
      if (el) el.style.display = '';
    }
  }
}

function updateGuessesLabel() {
  guessesLabel.textContent = `${guessesLeft} guess${guessesLeft === 1 ? '' : 'es'} remaining`;
  guessesLabel.style.color = guessesLeft <= 3 ? '#c0392b' : '';
}

function submitGuess() {
  const raw = input.value.trim().toLowerCase();
  if (!raw) return;
  input.value = '';

  const data = TAXONOMY[raw];
  const li = document.createElement('li');
  li.className = 'guess-row';

  if (!data) {
    li.innerHTML = `<span class="guess-name">${raw}</span><span class="hint-pill hint-cold">Unknown species</span>`;
    list.prepend(li);
    return;
  }

  if (data.clade === 9) {
    localStorage.setItem('gnomics_species_done', '1');
    document.getElementById('node-target')!.textContent = TARGET.name.charAt(0).toUpperCase() + TARGET.name.slice(1);
    document.getElementById('node-target')!.classList.add('phylo-node-hit', 'phylo-node-correct');
    for (let c = 0; c <= 8; c++) {
      const nodeId = CLADE_NODE[c];
      if (nodeId) document.getElementById(nodeId)?.classList.add('phylo-node-hit');
      const branchId = CLADE_BRANCH[c];
      if (branchId) {
        const el = document.getElementById(branchId);
        if (el) el.style.display = '';
      }
    }
    gameArea.style.display = 'none';
    successArea.style.display = 'block';
    return;
  }

  guessesLeft--;
  updateGuessesLabel();
  highlightNode(data.clade);

  // Show clade description
  if (CLADE_DESC[data.clade]) {
    cladeDesc.innerHTML = CLADE_DESC[data.clade];
    cladeDesc.style.display = 'block';
  }

  const cls = CLADE_CLASS[data.clade] ?? 'hint-cold';
  li.innerHTML = `<span class="guess-name">${raw}</span><span class="hint-pill ${cls}">${data.label}</span>`;
  list.prepend(li);

  if (guessesLeft === 0) {
    gameArea.style.display = 'none';
    failArea.style.display = 'block';
  }
}

retryBtn?.addEventListener('click', () => {
  guessesLeft = MAX_GUESSES;
  updateGuessesLabel();
  list.innerHTML = '';
  cladeDesc.style.display = 'none';
  document.querySelectorAll('.phylo-node').forEach(n => {
    n.classList.remove('phylo-node-hit', 'phylo-node-correct');
  });
  Object.values(CLADE_BRANCH).forEach(id => {
    const el = document.getElementById(id);
    if (el) el.style.display = 'none';
  });
  document.getElementById('node-target')!.textContent = '???';
  failArea.style.display = 'none';
  gameArea.style.display = 'block';
});

btn.addEventListener('click', submitGuess);
input.addEventListener('keydown', (e) => { if (e.key === 'Enter') submitGuess(); });
</script>
